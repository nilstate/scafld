def cmd_init(args):
    """Bootstrap Trellis workspace in the current directory."""
    project_root = Path.cwd()

    # Find trellis source
    script_dir = Path(__file__).resolve().parent.parent
    trellis_dir = script_dir
    trellis_rel = os.path.relpath(trellis_dir, project_root)

    print(f"{c(C_BOLD, 'Trellis init')}")
    print(f"  trellis: {trellis_rel}/")
    print(f"  project: {project_root}")
    print()

    # Copy template files
    print(f"{c(C_BOLD, 'Templates:')}")
    for fname in ["AGENTS.md", "CONVENTIONS.md", "CLAUDE.md"]:
        dest = project_root / fname
        src = trellis_dir / fname
        if dest.exists():
            print(f"  {c(C_DIM, 'skip')}: {fname} (exists)")
        elif src.exists():
            shutil.copy2(str(src), str(dest))
            print(f"  {c(C_GREEN, 'created')}: {fname}")
        else:
            print(f"  {c(C_YELLOW, 'missing')}: {fname} (not in trellis source)")
    print()

    # Create directories
    print(f"{c(C_BOLD, 'Directories:')}")
    for d in [DRAFTS_DIR, APPROVED_DIR, ACTIVE_DIR, ARCHIVE_DIR, LOGS_DIR]:
        p = project_root / d
        p.mkdir(parents=True, exist_ok=True)
        print(f"  {c(C_GREEN, 'ok')}: {d}/")
    print()

    # Symlink shared files
    print(f"{c(C_BOLD, 'Symlinks')} (from {trellis_rel}/):")
    symlinks = [
        (f"{AI_DIR}/config.yaml", f"{AI_DIR}/config.yaml"),
        (f"{AI_DIR}/schemas", f"{AI_DIR}/schemas"),
        (f"{AI_DIR}/prompts", f"{AI_DIR}/prompts"),
        (f"{SPECS_DIR}/README.md", f"{SPECS_DIR}/README.md"),
        (f"{AI_DIR}/OPERATORS.md", f"{AI_DIR}/OPERATORS.md"),
        (f"{AI_DIR}/README.md", f"{AI_DIR}/README.md"),
    ]
    for trellis_path, link_path in symlinks:
        link = project_root / link_path
        target_abs = trellis_dir / trellis_path
        if not target_abs.exists() and not target_abs.is_dir():
            continue
        if link.is_symlink():
            print(f"  {c(C_DIM, 'skip')}: {link_path} (symlink exists)")
        elif link.exists():
            print(f"  {c(C_DIM, 'skip')}: {link_path} (file exists)")
        else:
            link.parent.mkdir(parents=True, exist_ok=True)
            rel_target = os.path.relpath(target_abs, link.parent)
            link.symlink_to(rel_target)
            print(f"  {c(C_GREEN, 'linked')}: {link_path} -> {rel_target}")
    print()

    # Install CLI symlink
    print(f"{c(C_BOLD, 'CLI:')}")
    cli_src = (trellis_dir / "cli" / "trellis").resolve()
    local_bin = Path.home() / ".local" / "bin"
    cli_link = local_bin / "trellis"

    if cli_link.is_symlink() or cli_link.exists():
        existing_target = None
        if cli_link.is_symlink():
            existing_target = cli_link.resolve()
        if existing_target == cli_src:
            print(f"  {c(C_DIM, 'skip')}: ~/.local/bin/trellis (already linked)")
        else:
            print(f"  {c(C_YELLOW, 'skip')}: ~/.local/bin/trellis (exists, pointing elsewhere)")
            print(f"         to update: ln -sf {cli_src} {cli_link}")
    else:
        local_bin.mkdir(parents=True, exist_ok=True)
        cli_link.symlink_to(cli_src)
        print(f"  {c(C_GREEN, 'linked')}: ~/.local/bin/trellis -> {cli_src}")
        # Check if ~/.local/bin is in PATH
        path_dirs = os.environ.get("PATH", "").split(":")
        if str(local_bin) not in path_dirs:
            print(f"  {c(C_YELLOW, 'note')}: add ~/.local/bin to your PATH:")
            print(f'         export PATH="$HOME/.local/bin:$PATH"')
    print()

    print(f"""{c(C_BOLD, 'Done!')} Next steps:

  1. Edit {c(C_CYAN, 'AGENTS.md')} - add your project's invariants
  2. Edit {c(C_CYAN, 'CONVENTIONS.md')} - add your tech stack and patterns
  3. Edit {c(C_CYAN, 'CLAUDE.md')} - add project overview and commands
  4. Edit {c(C_CYAN, '.ai/config.yaml')} - replace placeholder validation commands

  Then: {c(C_BOLD, 'trellis new my-feature')} or tell your agent {c(C_BOLD, '"Let\'s plan [feature]."')}
""")


def cmd_new(args):
    """Create a new spec from template."""
    root = require_root()
    task_id = args.task_id

    # Validate task_id
    if not re.match(r'^[a-z0-9][a-z0-9-]*[a-z0-9]$', task_id) and not re.match(r'^[a-z0-9]$', task_id):
        print(f"{c(C_RED, 'error')}: task-id must be kebab-case (a-z, 0-9, hyphens)")
        sys.exit(1)

    # Check for conflicts
    existing = find_spec(root, task_id)
    if existing:
        rel = existing.relative_to(root)
        print(f"{c(C_RED, 'error')}: spec already exists: {rel}")
        sys.exit(1)

    dest_dir = root / DRAFTS_DIR
    dest_dir.mkdir(parents=True, exist_ok=True)
    dest = dest_dir / f"{task_id}.yaml"

    ts = now_iso()
    size = args.size or "small"
    risk = args.risk or "low"

    template = f'''spec_version: "1.1"
task_id: "{task_id}"
created: "{ts}"
updated: "{ts}"
status: "draft"

task:
  title: "{args.title or task_id.replace("-", " ").title()}"
  summary: >
    TODO: Describe the problem or goal.
  size: "{size}"
  risk_level: "{risk}"
  context:
    packages:
      - "TODO"
    invariants:
      - "domain_boundaries"
  objectives:
    - "TODO: Primary objective"
  touchpoints:
    - area: "TODO"
      description: "TODO"
  acceptance:
    definition_of_done:
      - id: "dod1"
        description: "TODO"
        status: "pending"
    validation:
      - id: "v1"
        type: "test"
        description: "TODO"
        command: "TODO"
        expected: "All tests pass"

planning_log:
  - timestamp: "{ts}"
    actor: "user"
    summary: "Spec created via trellis new"

phases:
  - id: "phase1"
    name: "TODO: Phase name"
    objective: "TODO: What this phase accomplishes"
    changes:
      - file: "TODO"
        action: "update"
        content_spec: |
          TODO: Describe the changes.
    acceptance_criteria:
      - id: "ac1_1"
        type: "test"
        description: "TODO"
        command: "TODO"
        expected: "TODO"
    status: "pending"

rollback:
  strategy: "per_phase"
  commands:
    phase1: "git checkout HEAD -- TODO"
'''

    dest.write_text(template)
    rel = dest.relative_to(root)
    print(f"{c(C_GREEN, 'created')}: {rel}")
    print(f"  title: {args.title or task_id.replace('-', ' ').title()}")
    print(f"   size: {size}  risk: {risk}")
    print()
    print(f"  Edit the spec, then: {c(C_BOLD, f'trellis approve {task_id}')}")


def cmd_status(args):
    """Show status of a spec."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()
    rel = spec.relative_to(root)

    status = yaml_read_field(text, "status") or "unknown"
    title = yaml_read_nested(text, "task", "title") or ""
    size = yaml_read_nested(text, "task", "size") or ""
    risk = yaml_read_nested(text, "task", "risk_level") or ""
    updated = yaml_read_field(text, "updated") or ""
    total, completed, failed, in_prog = count_phases(text)

    color = STATUS_COLORS.get(status, "")
    print(f"{c(C_BOLD, title)}")
    print(f"     id: {args.task_id}")
    print(f"   file: {c(C_DIM, str(rel))}")
    print(f" status: {c(color, status)}")
    if size or risk:
        print(f"   size: {size}  risk: {risk}")
    if total > 0:
        phase_parts = []
        if completed:
            phase_parts.append(c(C_GREEN, f"{completed} done"))
        if in_prog:
            phase_parts.append(c(C_CYAN, f"{in_prog} active"))
        if failed:
            phase_parts.append(c(C_RED, f"{failed} failed"))
        pending = total - completed - failed - in_prog
        if pending > 0:
            phase_parts.append(c(C_DIM, f"{pending} pending"))
        print(f" phases: {' / '.join(phase_parts)}  ({total} total)")
    if updated:
        print(f"updated: {c(C_DIM, updated)}")


def cmd_list(args):
    """List all specs."""
    root = require_root()
    specs = find_all_specs(root)

    if not specs:
        print(f"{c(C_DIM, 'No specs found.')}")
        print(f"  Create one: {c(C_BOLD, 'trellis new my-feature')}")
        return

    # Filter
    if args.filter:
        f = args.filter.lower()
        if f in ("draft", "drafts"):
            specs = [(s, l) for s, l in specs if l == "drafts"]
        elif f in ("approved",):
            specs = [(s, l) for s, l in specs if l == "approved"]
        elif f in ("active", "in_progress"):
            specs = [(s, l) for s, l in specs if l == "active"]
        elif f in ("archive", "archived", "completed", "done"):
            specs = [(s, l) for s, l in specs if l.startswith("archive")]
        else:
            # Search in task_id
            specs = [(s, l) for s, l in specs if f in s.stem.lower()]

    if not specs:
        print(f"{c(C_DIM, 'No matching specs.')}")
        return

    # Group by location
    groups = {}
    for spec_path, label in specs:
        groups.setdefault(label, []).append(spec_path)

    for label in groups:
        print(f"{c(C_BOLD, label)}/")
        for spec_path in groups[label]:
            text = spec_path.read_text()
            status = yaml_read_field(text, "status") or "unknown"
            title = yaml_read_nested(text, "task", "title") or spec_path.stem
            color = STATUS_COLORS.get(status, "")
            total, completed, _, _ = count_phases(text)
            phase_str = ""
            if total > 0:
                phase_str = f" [{completed}/{total}]"
            # Truncate title
            max_title = 50
            if len(title) > max_title:
                title = title[:max_title - 1] + "…"
            print(f"  {c(color, f'{status:14s}')} {spec_path.stem:30s} {c(C_DIM, title)}{phase_str}")
        print()


def cmd_approve(args):
    """Move spec from drafts to approved."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    move_spec(root, spec, "approved")


def cmd_start(args):
    """Move spec from approved to active."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    move_spec(root, spec, "in_progress")


def check_self_eval(text, task_id):
    """Warn if self-eval looks like a rubber stamp."""
    # Look for self_eval or perf_eval score
    score_match = re.search(r'(?:self_eval|perf_eval|score):\s*(\d+)', text)
    if not score_match:
        print(f"  {c(C_YELLOW, 'warn')}: no self-eval score found in spec")
        return

    score = int(score_match.group(1))
    has_deviations = bool(re.search(r'deviations:', text, re.MULTILINE))
    has_improvements = bool(re.search(r'improvements:', text, re.MULTILINE))

    if score >= 9 and not has_deviations and not has_improvements:
        print(f"  {c(C_YELLOW, 'warn')}: self-eval {score}/10 with no deviations or improvements noted")
        print(f"         scores above 8 should document at least one deviation or improvement")
    elif score == 10:
        print(f"  {c(C_YELLOW, 'note')}: perfect 10/10 - are you sure? 10 means flawless with improvements beyond spec")


def cmd_complete(args):
    """Move spec from active to archive (completed)."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    # Check for exec results - warn if no criteria were executed
    has_results = bool(re.search(r'result:\s*"?(pass|fail)"?', text, re.MULTILINE))
    if not has_results:
        print(f"  {c(C_YELLOW, 'warn')}: no exec results recorded. Run '{c(C_BOLD, f'trellis exec {args.task_id}')}' first")

    # Check self-eval honesty
    check_self_eval(text, args.task_id)

    move_spec(root, spec, "completed")


def cmd_fail(args):
    """Move spec from active to archive (failed)."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    move_spec(root, spec, "failed")


def cmd_cancel(args):
    """Move spec to archive (cancelled)."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    move_spec(root, spec, "cancelled")


def cmd_validate(args):
    """Validate a spec against the JSON schema."""
    root = require_root()
    spec = require_spec(root, args.task_id)

    # Find schema - check symlinked and direct paths
    schema_path = root / SCHEMA_PATH
    if not schema_path.exists():
        # Try trellis submodule
        trellis = find_trellis_dir(root)
        if trellis:
            schema_path = trellis / SCHEMA_PATH
    if not schema_path.exists():
        print(f"{c(C_RED, 'error')}: schema not found at {SCHEMA_PATH}")
        sys.exit(1)

    schema_text = schema_path.read_text()
    try:
        schema = json.loads(schema_text)
    except json.JSONDecodeError as e:
        print(f"{c(C_RED, 'error')}: invalid schema JSON: {e}")
        sys.exit(1)

    # Basic YAML-to-dict parsing using only stdlib
    # We'll do structural validation of required fields
    text = spec.read_text()
    rel = spec.relative_to(root)
    errors = []

    required_top = schema.get("required", [])
    for field in required_top:
        if not yaml_read_field(text, field):
            # Check if it's a block field (like task:, phases:)
            if not re.search(rf'^{field}:', text, re.MULTILINE):
                errors.append(f"missing required field: {field}")

    # Check task_id format
    task_id = yaml_read_field(text, "task_id")
    if task_id and not re.match(r'^[a-z0-9-]+$', task_id):
        errors.append(f"task_id must be kebab-case: got '{task_id}'")

    # Check status enum
    status = yaml_read_field(text, "status")
    valid_statuses = ["draft", "blocked", "under_review", "approved", "in_progress",
                      "completed", "failed", "cancelled"]
    if status and status not in valid_statuses:
        errors.append(f"invalid status: '{status}' (expected one of: {', '.join(valid_statuses)})")

    # Check spec_version
    sv = yaml_read_field(text, "spec_version")
    if sv and not re.match(r'^\d+\.\d+$', sv):
        errors.append(f"spec_version must be semver: got '{sv}'")

    # Check phases exist
    if not re.search(r'^phases:', text, re.MULTILINE):
        errors.append("missing required field: phases")
    else:
        # Check each phase has required fields
        phase_ids = re.findall(r'^\s+-\s+id:\s*"?(phase\d+)"?', text, re.MULTILINE)
        if not phase_ids:
            errors.append("phases array is empty (at least 1 phase required)")

    # Check planning_log exists
    if not re.search(r'^planning_log:', text, re.MULTILINE):
        errors.append("missing required field: planning_log")

    # Check task block required fields
    if re.search(r'^task:', text, re.MULTILINE):
        task_required = ["title", "summary", "size", "risk_level"]
        for field in task_required:
            if not yaml_read_nested(text, "task", field):
                errors.append(f"missing required task field: task.{field}")
    else:
        errors.append("missing required field: task")

    if errors:
        print(f"{c(C_RED, 'FAIL')}: {rel}")
        for e in errors:
            print(f"  - {e}")
        sys.exit(1)
    else:
        print(f"{c(C_GREEN, 'PASS')}: {rel}")
        print(f"  spec_version: {sv}")
        print(f"  task_id: {task_id}")
        print(f"  status: {status}")
        total, completed, failed, in_prog = count_phases(text)
        print(f"  phases: {total}")


def parse_acceptance_criteria(text):
    """Extract acceptance criteria from all phases."""
    criteria = []
    lines = text.splitlines()
    current_phase = None
    in_ac = False
    current_ac = {}

    for i, line in enumerate(lines):
        # Track phase id
        m = re.match(r'^\s+-\s+id:\s*"?(phase\d+)"?', line)
        if m:
            current_phase = m.group(1)
            in_ac = False
            continue

        if re.match(r'^\s+acceptance_criteria:', line):
            in_ac = True
            continue

        if in_ac:
            # New criteria item
            m = re.match(r'^\s+-\s+id:\s*"?([^"]+)"?', line)
            if m:
                if current_ac.get("id"):
                    criteria.append(current_ac)
                current_ac = {"id": m.group(1), "phase": current_phase}
                continue

            # End of acceptance_criteria block
            if line.strip() and not line.startswith(' ' * 6) and not line.startswith('\t\t\t'):
                if not line.startswith(' ' * 8) and re.match(r'^\s{4}\w', line):
                    if current_ac.get("id"):
                        criteria.append(current_ac)
                        current_ac = {}
                    in_ac = False
                    continue

            # Fields within criteria
            for field in ("type", "description", "command", "expected"):
                m = re.match(rf'^\s+{field}:\s*"?([^"]+)"?\s*$', line)
                if m:
                    current_ac[field] = m.group(1).strip().strip('"').strip("'")

    if current_ac.get("id"):
        criteria.append(current_ac)

    return criteria


def record_exec_result(text, ac_id, passed, output_snippet=""):
    """Record execution result for an acceptance criterion in the spec."""
    # Find the acceptance criterion and add/update result fields
    lines = text.splitlines(True)
    result_lines = []
    found = False
    i = 0
    while i < len(lines):
        result_lines.append(lines[i])
        if re.search(rf'id:\s*"?{re.escape(ac_id)}"?', lines[i]):
            found = True
            # Skip ahead to find where this criterion's fields end
            indent = len(lines[i]) - len(lines[i].lstrip())
            i += 1
            # Collect existing fields, skip old result/result_output
            ac_fields = []
            while i < len(lines):
                line = lines[i]
                if not line.strip():
                    break
                line_indent = len(line) - len(line.lstrip())
                if line_indent <= indent and line.strip().startswith('- '):
                    break
                if line_indent <= indent and not line.strip().startswith('-') and line_indent <= indent:
                    # Check if it's a new block at same or lower indent
                    if line_indent <= indent:
                        break
                if not re.match(r'^\s+(result|result_output|executed_at):', line):
                    ac_fields.append(line)
                i += 1
            result_lines.extend(ac_fields)
            # Add result fields
            pad = ' ' * (indent + 8)
            result_lines.append(f'{pad}result: "{"pass" if passed else "fail"}"\n')
            result_lines.append(f'{pad}executed_at: "{now_iso()}"\n')
            if output_snippet:
                # Truncate and sanitize
                snippet = output_snippet[:200].replace('"', '\\"').replace('\n', ' ')
                result_lines.append(f'{pad}result_output: "{snippet}"\n')
            continue
        i += 1

    return ''.join(result_lines)


def cmd_exec(args):
    """Run acceptance criteria commands and record results."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    status = yaml_read_field(text, "status")
    if status not in ("in_progress", "approved"):
        print(f"{c(C_RED, 'error')}: spec must be in_progress or approved to exec (current: {status})")
        sys.exit(1)

    criteria = parse_acceptance_criteria(text)
    if not criteria:
        print(f"{c(C_YELLOW, 'warn')}: no acceptance criteria found in spec")
        return

    # Filter by phase if specified
    if args.phase:
        criteria = [ac for ac in criteria if ac.get("phase") == args.phase]
        if not criteria:
            print(f"{c(C_YELLOW, 'warn')}: no criteria found for phase {args.phase}")
            return

    # Filter to only runnable criteria (have a command)
    runnable = [ac for ac in criteria if ac.get("command") and ac["command"] != "TODO"]
    manual = [ac for ac in criteria if not ac.get("command") or ac["command"] == "TODO"]

    if not runnable and not manual:
        print(f"{c(C_YELLOW, 'warn')}: no criteria found")
        return

    print(f"{c(C_BOLD, f'Executing acceptance criteria for {args.task_id}')}")
    if args.phase:
        print(f"  phase: {args.phase}")
    print()

    passed = 0
    failed = 0
    skipped = 0

    for ac in runnable:
        ac_id = ac["id"]
        cmd = ac["command"]
        expected = ac.get("expected", "")
        desc = ac.get("description", ac_id)

        print(f"  {c(C_CYAN, ac_id)}: {desc}")
        print(f"    $ {c(C_DIM, cmd)}")

        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True,
                timeout=120, cwd=str(root),
            )
            output = (result.stdout + result.stderr).strip()

            # Determine pass/fail
            ac_passed = result.returncode == 0
            if expected and expected.lower() == "no matches":
                ac_passed = result.returncode != 0 or not output

            if ac_passed:
                print(f"    {c(C_GREEN, 'PASS')}")
                passed += 1
            else:
                print(f"    {c(C_RED, 'FAIL')} (exit code {result.returncode})")
                if output:
                    for line in output.splitlines()[:5]:
                        print(f"    {c(C_DIM, line)}")
                failed += 1

            text = record_exec_result(text, ac_id, ac_passed, output[:200])

        except subprocess.TimeoutExpired:
            print(f"    {c(C_RED, 'TIMEOUT')} (120s)")
            text = record_exec_result(text, ac_id, False, "Command timed out after 120s")
            failed += 1
        except Exception as e:
            print(f"    {c(C_RED, 'ERROR')}: {e}")
            text = record_exec_result(text, ac_id, False, str(e))
            failed += 1

    for ac in manual:
        ac_id = ac["id"]
        desc = ac.get("description", ac_id)
        print(f"  {c(C_DIM, ac_id)}: {desc} (manual - skipped)")
        skipped += 1

    # Write results back
    spec.write_text(text)

    print()
    summary_parts = [c(C_GREEN, f"{passed} passed")]
    if failed:
        summary_parts.append(c(C_RED, f"{failed} failed"))
    if skipped:
        summary_parts.append(c(C_DIM, f"{skipped} manual"))
    print(f"  {' / '.join(summary_parts)}")

    if failed:
        sys.exit(1)


def cmd_audit(args):
    """Compare spec changes against actual git diff to detect scope creep."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    # Extract declared files from phases[*].changes[*].file
    declared = set()
    for m in re.finditer(r'^\s+file:\s*"?([^"\n]+)"?', text, re.MULTILINE):
        f = m.group(1).strip()
        if f != "TODO":
            declared.add(f)

    if not declared:
        print(f"{c(C_YELLOW, 'warn')}: no files declared in spec phases")
        return

    # Get actual changed files from git
    base_ref = args.base or "HEAD~1"
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", base_ref],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.returncode != 0:
            # Try diffing against main/master
            for branch in ("main", "master"):
                result = subprocess.run(
                    ["git", "diff", "--name-only", branch],
                    capture_output=True, text=True, cwd=str(root),
                )
                if result.returncode == 0:
                    base_ref = branch
                    break
            else:
                print(f"{c(C_RED, 'error')}: git diff failed. Use --base to specify a ref.")
                sys.exit(1)

        actual = set(line.strip() for line in result.stdout.splitlines() if line.strip())
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)

    if not actual:
        print(f"{c(C_DIM, 'No files changed in git diff')}")
        return

    print(f"{c(C_BOLD, f'Audit: {args.task_id}')} (vs {base_ref})")
    print()

    # Scope creep: files changed but not in spec
    undeclared = actual - declared
    # Missing: files in spec but not changed
    missing = declared - actual
    # Matched
    matched = declared & actual

    if matched:
        print(f"  {c(C_GREEN, 'Declared & changed')} ({len(matched)}):")
        for f in sorted(matched):
            print(f"    {c(C_GREEN, '✓')} {f}")

    if undeclared:
        print(f"\n  {c(C_RED, 'Scope creep - changed but not in spec')} ({len(undeclared)}):")
        for f in sorted(undeclared):
            print(f"    {c(C_RED, '!')} {f}")

    if missing:
        print(f"\n  {c(C_YELLOW, 'In spec but not changed')} ({len(missing)}):")
        for f in sorted(missing):
            print(f"    {c(C_YELLOW, '?')} {f}")

    print()
    if undeclared:
        pct = len(undeclared) / len(actual) * 100
        print(f"  {c(C_RED, f'Scope drift: {pct:.0f}%')} ({len(undeclared)}/{len(actual)} files undeclared)")
        sys.exit(1)
    else:
        print(f"  {c(C_GREEN, 'Clean')} - all changes match spec")


def cmd_diff(args):
    """Show git diff for a spec file."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    rel = spec.relative_to(root)

    try:
        result = subprocess.run(
            ["git", "log", "--oneline", "-10", "--follow", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.stdout.strip():
            print(f"{c(C_BOLD, f'History: {rel}')}")
            print(result.stdout)
        else:
            print(f"{c(C_DIM, 'No git history for this spec')}")

        # Show diff if uncommitted changes exist
        diff_result = subprocess.run(
            ["git", "diff", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if diff_result.stdout.strip():
            print(f"{c(C_BOLD, 'Uncommitted changes:')}")
            print(diff_result.stdout)
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)


def cmd_version(args):
    print(f"trellis {VERSION}")


