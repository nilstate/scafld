    trellis_entries = [
        "# Trellis",
        ".ai/logs/",
    ]
    if gitignore.exists():
        existing = gitignore.read_text()
        if "# Trellis" in existing:
            print(f"  {c(C_DIM, 'skip')}: .gitignore (Trellis entries exist)")
        else:
            with open(gitignore, "a") as f:
                f.write("\n" + "\n".join(trellis_entries) + "\n")
            print(f"  {c(C_GREEN, 'updated')}: .gitignore (added Trellis entries)")
    else:
        gitignore.write_text("\n".join(trellis_entries) + "\n")
        print(f"  {c(C_GREEN, 'created')}: .gitignore")
    print()

    print(f"""{c(C_BOLD, 'Done!')} Next steps:

  1. Edit {c(C_CYAN, 'AGENTS.md')} - add your project's invariants
  2. Edit {c(C_CYAN, 'CONVENTIONS.md')} - add your tech stack and patterns
