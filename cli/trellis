        print(f"  phases: {total}")


def parse_yaml_value(raw):
    """Parse a YAML scalar value, handling quotes and escapes."""
    v = raw.strip()
    if not v:
        return ""
    # Double-quoted: unescape \"
    if v.startswith('"') and v.endswith('"'):
        return v[1:-1].replace('\\"', '"')
    # Single-quoted
    if v.startswith("'") and v.endswith("'"):
        return v[1:-1].replace("''", "'")
    return v


def parse_acceptance_criteria(text):
    """Extract acceptance criteria from all phases using indent-aware parsing."""
    criteria = []
    lines = text.splitlines()
    current_phase = None
    i = 0

    while i < len(lines):
        line = lines[i]

        # Track phase id - matches both "- id: phase1" and "- id: \"phase1\""
        m = re.match(r'^(\s+)-\s+id:\s*(.+)$', line)
        if m:
            val = parse_yaml_value(m.group(2))
            if re.match(r'^phase\d+$', val):
                current_phase = val
                i += 1
                continue

        # Enter acceptance_criteria or validation block (under a phase)
        if current_phase and re.match(r'^(\s+)(acceptance_criteria|validation)\s*:', line):
            block_indent = len(line) - len(line.lstrip())
            i += 1
            # Parse list items in this block
            while i < len(lines):
                item_line = lines[i]
                # Empty line - skip
                if not item_line.strip():
                    i += 1
                    continue
                item_indent = len(item_line) - len(item_line.lstrip())
                # Dedented past block - exit
                if item_indent <= block_indent and item_line.strip():
                    break
                # List item start: "- id: ..." or "- dod_id: ..."
                m = re.match(r'^(\s+)-\s+(id|dod_id):\s*(.+)$', item_line)
                if m:
                    item_base_indent = len(m.group(1))
                    ac = {"id": parse_yaml_value(m.group(3)), "phase": current_phase}
                    i += 1
                    # Read fields for this item
                    while i < len(lines):
                        field_line = lines[i]
                        if not field_line.strip():
                            i += 1
                            continue
                        fi = len(field_line) - len(field_line.lstrip())
                        # Dedented to item level or less - done with this item
                        if fi <= item_base_indent and field_line.strip():
                            break
                        # New list item at same level
                        if field_line.strip().startswith('- ') and fi == item_base_indent:
                            break
                        # Parse key: value
                        fm = re.match(r'^\s+([\w_]+):\s*(.*)$', field_line)
                        if fm:
                            key = fm.group(1)
                            if key in ("type", "description", "command", "expected", "cwd", "result"):
                                ac[key] = parse_yaml_value(fm.group(2))
                        i += 1
                    criteria.append(ac)
                else:
                    i += 1
            continue

        i += 1

    return criteria


def record_exec_result(text, ac_id, passed, output_snippet=""):
    """Record execution result for an acceptance criterion in the spec."""
    lines = text.splitlines(True)
    result = []
    i = 0
    while i < len(lines):
        line = lines[i]
        # Match the id line for this criterion (id: or dod_id:)
        if re.search(rf'(?:id|dod_id):\s*"?{re.escape(ac_id)}"?\s*$', line):
            result.append(line)
            # Determine the indent for sibling fields
            item_match = re.match(r'^(\s+)-\s+', line)
            if item_match:
                field_indent = ' ' * (len(item_match.group(1)) + 2)
            else:
                field_indent = ' ' * (len(line) - len(line.lstrip()))
            i += 1
            # Copy existing fields, skip old result/executed_at/result_output
            while i < len(lines):
                fl = lines[i]
                if not fl.strip():
                    break
                fi = len(fl) - len(fl.lstrip())
                expected_fi = len(field_indent)
                # Dedented or new list item - done
                if fi < expected_fi:
                    break
                if fi == expected_fi - 2 and fl.strip().startswith('- '):
                    break
                if re.match(r'^\s+(result|result_output|executed_at):', fl):
                    i += 1
                    continue
                result.append(fl)
                i += 1
            # Append new result fields
            result.append(f'{field_indent}result: "{"pass" if passed else "fail"}"\n')
            result.append(f'{field_indent}executed_at: "{now_iso()}"\n')
            if output_snippet:
                snippet = output_snippet[:200].replace('"', '\\"').replace('\n', ' ')
                result.append(f'{field_indent}result_output: "{snippet}"\n')
            continue
        result.append(line)
        i += 1

    return ''.join(result)


def cmd_exec(args):
    """Run acceptance criteria commands and record results."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    status = yaml_read_field(text, "status")
    if status not in ("in_progress", "approved"):
        print(f"{c(C_RED, 'error')}: spec must be in_progress or approved to exec (current: {status})")
        sys.exit(1)

    criteria = parse_acceptance_criteria(text)
    if not criteria:
        print(f"{c(C_YELLOW, 'warn')}: no acceptance criteria found in spec")
        return

    # Filter by phase if specified
    if args.phase:
        criteria = [ac for ac in criteria if ac.get("phase") == args.phase]
        if not criteria:
            print(f"{c(C_YELLOW, 'warn')}: no criteria found for phase {args.phase}")
            return

    # Resume mode: skip criteria that already passed
    skipped_resume = 0
    if args.resume:
        before = len(criteria)
        criteria = [ac for ac in criteria if ac.get("result") != "pass"]
        skipped_resume = before - len(criteria)

    # Filter to only runnable criteria (have a command)
    runnable = [ac for ac in criteria if ac.get("command") and ac["command"] != "TODO"]
    manual = [ac for ac in criteria if not ac.get("command") or ac["command"] == "TODO"]

    if not runnable and not manual and not skipped_resume:
        print(f"{c(C_YELLOW, 'warn')}: no criteria found")
        return

    print(f"{c(C_BOLD, f'Executing acceptance criteria for {args.task_id}')}")
    if args.phase:
        print(f"  phase: {args.phase}")
    if skipped_resume:
        print(f"  {c(C_DIM, f'resume: skipping {skipped_resume} already-passed criteria')}")
    print()

    passed = 0
    failed = 0
    skipped = 0

    for ac in runnable:
        ac_id = ac["id"]
        cmd = ac["command"]
        expected = ac.get("expected", "")
        desc = ac.get("description", ac_id)

        print(f"  {c(C_CYAN, ac_id)}: {desc}")

        # Resolve working directory (default: workspace root)
        ac_cwd = root
        if ac.get("cwd"):
            ac_cwd = (root / ac["cwd"]).resolve()
            if not str(ac_cwd).startswith(str(root.resolve())):
                print(f"    {c(C_RED, 'ERROR')}: cwd '{ac['cwd']}' escapes workspace root")
                text = record_exec_result(text, ac_id, False, f"cwd '{ac['cwd']}' escapes workspace root")
                failed += 1
                continue
            if not ac_cwd.is_dir():
                print(f"    {c(C_RED, 'ERROR')}: cwd '{ac['cwd']}' is not a directory")
                text = record_exec_result(text, ac_id, False, f"cwd '{ac['cwd']}' not found")
                failed += 1
                continue
            cwd_suffix = f"  {c(C_DIM, '(in ' + ac['cwd'] + '/)')}"
        else:
            cwd_suffix = ""
        print(f"    $ {c(C_DIM, cmd)}{cwd_suffix}")

        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True,
                timeout=120, cwd=str(ac_cwd),
            )
            output = (result.stdout + result.stderr).strip()

            # Determine pass/fail
            ac_passed = result.returncode == 0
            if expected and expected.lower() == "no matches":
                ac_passed = result.returncode != 0 or not output

            if ac_passed:
                print(f"    {c(C_GREEN, 'PASS')}")
                passed += 1
            else:
                print(f"    {c(C_RED, 'FAIL')} (exit code {result.returncode})")
                if output:
                    for line in output.splitlines()[:5]:
                        print(f"    {c(C_DIM, line)}")
                failed += 1

            text = record_exec_result(text, ac_id, ac_passed, output[:200])

        except subprocess.TimeoutExpired:
            print(f"    {c(C_RED, 'TIMEOUT')} (120s)")
            text = record_exec_result(text, ac_id, False, "Command timed out after 120s")
            failed += 1
        except Exception as e:
            print(f"    {c(C_RED, 'ERROR')}: {e}")
            text = record_exec_result(text, ac_id, False, str(e))
            failed += 1

    for ac in manual:
        ac_id = ac["id"]
        desc = ac.get("description", ac_id)
        print(f"  {c(C_DIM, ac_id)}: {desc} (manual - skipped)")
        skipped += 1

    # Write results back
    spec.write_text(text)

    print()
    summary_parts = []
    if passed or skipped_resume:
        total_pass = passed + skipped_resume
        label = f"{total_pass} passed"
        if skipped_resume:
            label += f" ({skipped_resume} prior)"
        summary_parts.append(c(C_GREEN, label))
    if failed:
        summary_parts.append(c(C_RED, f"{failed} failed"))
    if skipped:
        summary_parts.append(c(C_DIM, f"{skipped} manual"))
    print(f"  {' / '.join(summary_parts)}")

    if failed:
        sys.exit(1)


def cmd_audit(args):
    """Compare spec changes against actual git diff to detect scope creep."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    # Extract declared files from phases[*].changes[*].file
    declared = set()
    for m in re.finditer(r'^\s+file:\s*"?([^"\n]+)"?', text, re.MULTILINE):
        f = m.group(1).strip()
        if f != "TODO":
            declared.add(f)

    if not declared:
        print(f"{c(C_YELLOW, 'warn')}: no files declared in spec phases")
        return

    # Get actual changed files from git
    base_ref = args.base or "HEAD~1"
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", base_ref],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.returncode != 0:
            # Try diffing against main/master
            for branch in ("main", "master"):
                result = subprocess.run(
                    ["git", "diff", "--name-only", branch],
                    capture_output=True, text=True, cwd=str(root),
                )
                if result.returncode == 0:
                    base_ref = branch
                    break
            else:
                print(f"{c(C_RED, 'error')}: git diff failed. Use --base to specify a ref.")
                sys.exit(1)

        actual = set(line.strip() for line in result.stdout.splitlines() if line.strip())
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)

    if not actual:
        print(f"{c(C_DIM, 'No files changed in git diff')}")
        return

    print(f"{c(C_BOLD, f'Audit: {args.task_id}')} (vs {base_ref})")
    print()

    # Scope creep: files changed but not in spec
    undeclared = actual - declared
    # Missing: files in spec but not changed
    missing = declared - actual
    # Matched
    matched = declared & actual

    if matched:
        print(f"  {c(C_GREEN, 'Declared & changed')} ({len(matched)}):")
        for f in sorted(matched):
            print(f"    {c(C_GREEN, '✓')} {f}")

    if undeclared:
        print(f"\n  {c(C_RED, 'Scope creep - changed but not in spec')} ({len(undeclared)}):")
        for f in sorted(undeclared):
            print(f"    {c(C_RED, '!')} {f}")

    if missing:
        print(f"\n  {c(C_YELLOW, 'In spec but not changed')} ({len(missing)}):")
        for f in sorted(missing):
            print(f"    {c(C_YELLOW, '?')} {f}")

    print()
    if undeclared:
        pct = len(undeclared) / len(actual) * 100
        print(f"  {c(C_RED, f'Scope drift: {pct:.0f}%')} ({len(undeclared)}/{len(actual)} files undeclared)")
        sys.exit(1)
    else:
        print(f"  {c(C_GREEN, 'Clean')} - all changes match spec")


def cmd_diff(args):
    """Show git diff for a spec file."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    rel = spec.relative_to(root)

    try:
        result = subprocess.run(
            ["git", "log", "--oneline", "-10", "--follow", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.stdout.strip():
            print(f"{c(C_BOLD, f'History: {rel}')}")
            print(result.stdout)
        else:
            print(f"{c(C_DIM, 'No git history for this spec')}")

        # Show diff if uncommitted changes exist
        diff_result = subprocess.run(
            ["git", "diff", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if diff_result.stdout.strip():
            print(f"{c(C_BOLD, 'Uncommitted changes:')}")
            print(diff_result.stdout)
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)


def cmd_report(args):
    """Aggregate stats across archived specs."""
    root = require_root()
    specs = find_all_specs(root)

    if not specs:
        print(f"{c(C_DIM, 'No specs found.')}")
        return

    # Collect stats
    total = 0
    by_status = {}
    by_month = {}
    sizes = {}
    risks = {}
    self_eval_scores = []
    exec_pass = 0
    exec_fail = 0
    exec_total = 0
    specs_with_exec = 0
    specs_without_exec = 0
    phase_counts = []

    for spec_path, label in specs:
        text = spec_path.read_text()
        total += 1

        status = yaml_read_field(text, "status") or "unknown"
        by_status[status] = by_status.get(status, 0) + 1

        # Month grouping from label
        if label.startswith("archive/"):
            month = label.split("/", 1)[1]
            by_month[month] = by_month.get(month, 0) + 1

        size = yaml_read_nested(text, "task", "size") or "unknown"
        sizes[size] = sizes.get(size, 0) + 1

        risk = yaml_read_nested(text, "task", "risk_level") or "unknown"
        risks[risk] = risks.get(risk, 0) + 1

        # Self-eval scores
        score_match = re.search(r'total:\s*(\d+)', text)
        if score_match:
            self_eval_scores.append(int(score_match.group(1)))

        # Exec results
        passes = len(re.findall(r'result:\s*"?pass"?', text))
        fails = len(re.findall(r'result:\s*"?fail"?', text))
        if passes or fails:
            exec_pass += passes
            exec_fail += fails
            exec_total += passes + fails
            specs_with_exec += 1
        else:
            specs_without_exec += 1

        # Phase counts
        t, _, _, _ = count_phases(text)
        if t > 0:
            phase_counts.append(t)

    # Print report
    print(f"{c(C_BOLD, 'Trellis Report')}")
    print(f"  {total} total specs")
    print()

    # Status breakdown
    print(f"{c(C_BOLD, 'By status:')}")
    for status in ["completed", "failed", "cancelled", "in_progress", "approved", "draft"]:
        count = by_status.get(status, 0)
        if count:
            color = STATUS_COLORS.get(status, "")
            pct = count / total * 100
            bar = "#" * int(pct / 2)
            print(f"  {c(color, f'{status:14s}')} {count:4d}  {pct:5.1f}%  {c(C_DIM, bar)}")
    print()

    # Monthly activity
    if by_month:
        print(f"{c(C_BOLD, 'By month:')}")
        for month in sorted(by_month.keys(), reverse=True)[:6]:
            print(f"  {month}  {by_month[month]:3d} specs")
        print()

    # Size/risk distribution
    if any(v != "unknown" for v in sizes):
        print(f"{c(C_BOLD, 'Sizes:')}  ", end="")
        print("  ".join(f"{s}: {sizes.get(s, 0)}" for s in ["micro", "small", "medium", "large"] if sizes.get(s, 0)))
        print(f"{c(C_BOLD, 'Risks:')}  ", end="")
        print("  ".join(f"{r}: {risks.get(r, 0)}" for r in ["low", "medium", "high"] if risks.get(r, 0)))
        print()

    # Self-eval stats
    if self_eval_scores:
        avg = sum(self_eval_scores) / len(self_eval_scores)
        perfect = sum(1 for s in self_eval_scores if s == 10)
        below_7 = sum(1 for s in self_eval_scores if s < 7)
        print(f"{c(C_BOLD, 'Self-eval:')}")
        print(f"  avg: {avg:.1f}/10  ({len(self_eval_scores)} scored)")
        if perfect:
            pct = perfect / len(self_eval_scores) * 100
            color = C_YELLOW if pct > 50 else C_DIM
            print(f"  {c(color, f'perfect 10s: {perfect} ({pct:.0f}%)')}")
        if below_7:
            print(f"  below threshold: {below_7}")
        print()

    # Exec results
    if exec_total:
        pass_rate = exec_pass / exec_total * 100
        print(f"{c(C_BOLD, 'Exec results:')}")
        print(f"  {c(C_GREEN, f'{exec_pass} passed')} / {c(C_RED, f'{exec_fail} failed')}  ({pass_rate:.0f}% pass rate)")
        print(f"  {specs_with_exec} specs with results, {specs_without_exec} without")
        print()

    # Phase stats
    if phase_counts:
        avg_phases = sum(phase_counts) / len(phase_counts)
        print(f"{c(C_BOLD, 'Phases:')}  avg {avg_phases:.1f} per spec, range {min(phase_counts)}-{max(phase_counts)}")
        print()


