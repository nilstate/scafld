""")


def parse_review_file(review_path):
    """Parse the latest review round and validate the Review Artifact v2 contract."""
    parsed = {
        "exists": review_path.exists(),
        "review_count": 0,
        "verdict": None,
        "blocking": [],
        "non_blocking": [],
        "metadata": None,
        "automated_passes": normalize_automated_passes(),
        "round_status": None,
        "reviewer_mode": None,
        "errors": [],
    }
    if not review_path.exists():
        return parsed

    text = review_path.read_text()
    matches = list(re.finditer(r'^## Review \d+\s+—.*$', text, re.MULTILINE))
    parsed["review_count"] = len(matches)
    if not matches:
        parsed["errors"].append("review file has no review rounds")
        return parsed

    last_section = text[matches[-1].end():]

    def section_body(heading):
        match = re.search(
            rf'^### {re.escape(heading)}\s*\n(.*?)(?=^### |\Z)',
            last_section,
            re.MULTILINE | re.DOTALL,
        )
        return match.group(1) if match else None

    sections = {}
    for heading in ("Metadata", "Automated Passes", "Blocking", "Non-blocking", "Verdict"):
        body = section_body(heading)
        sections[heading] = body
        if body is None:
            parsed["errors"].append(f"latest review round is missing ### {heading}")

    blocking = []
    non_blocking = []
    for heading, bucket in (("Blocking", blocking), ("Non-blocking", non_blocking)):
        body = sections.get(heading)
        if body is None:
            continue
        for line in body.strip().splitlines():
            stripped = line.strip()
            if not stripped:
                continue
            normalized = stripped.lower().strip(".")
            if normalized in {"none", "- none", "n/a", "(none)"}:
                continue
            if stripped.startswith("* "):
                stripped = "- " + stripped[2:].strip()
            if stripped.startswith("- "):
                bucket.append(stripped)
    parsed["blocking"] = blocking
    parsed["non_blocking"] = non_blocking

    metadata_body = sections.get("Metadata")
    if metadata_body is not None:
        metadata_match = re.search(r'```json\s*\n(.*?)\n```', metadata_body, re.DOTALL)
        if not metadata_match:
            parsed["errors"].append("latest review metadata must contain a fenced json block")
        else:
            try:
                metadata = json.loads(metadata_match.group(1))
            except json.JSONDecodeError as e:
                parsed["errors"].append(f"latest review metadata is invalid JSON: {e}")
            else:
                parsed["metadata"] = metadata
                parsed["automated_passes"] = normalize_automated_passes(metadata.get("automated_passes"))
                parsed["round_status"] = metadata.get("round_status")
                parsed["reviewer_mode"] = metadata.get("reviewer_mode")
                for issue in validate_review_metadata(metadata):
                    parsed["errors"].append(f"metadata: {issue}")

    verdict_body = sections.get("Verdict")
    verdict = None
    if verdict_body is None:
        parsed["errors"].append("latest review round is missing a verdict body")
    else:
        normalized_verdict = re.sub(r'[`*_]+', ' ', verdict_body.lower())
        normalized_verdict = re.sub(r'\s+', ' ', normalized_verdict).strip()
        if "pass with issues" in normalized_verdict:
            verdict = "pass_with_issues"
        elif "pass_with_issues" in normalized_verdict:
            verdict = "pass_with_issues"
        elif re.search(r'\bfail\b', normalized_verdict):
            verdict = "fail"
        elif re.search(r'\bpass\b', normalized_verdict):
            verdict = "pass"
        elif re.search(r'\bincomplete\b', normalized_verdict):
            verdict = "incomplete"
        elif normalized_verdict:
            parsed["errors"].append("latest review verdict is invalid")
        else:
            parsed["errors"].append("latest review verdict is empty")

    if verdict is None:
        if blocking:
            verdict = "fail"
        elif non_blocking:
            verdict = "pass_with_issues"

    if verdict == "fail" and not blocking:
        parsed["errors"].append("verdict fail requires at least one blocking finding")
    if verdict == "pass_with_issues":
        if blocking:
            parsed["errors"].append("pass_with_issues cannot include blocking findings")
        if not non_blocking:
            parsed["errors"].append("pass_with_issues requires at least one non-blocking finding")
    if verdict == "pass":
        if blocking:
            parsed["errors"].append("pass verdict cannot include blocking findings")
        if non_blocking:
            parsed["errors"].append("pass verdict cannot include non-blocking findings")
    if verdict == "incomplete" and parsed["round_status"] == "completed":
        parsed["errors"].append("completed review round cannot use verdict=incomplete")

    parsed["verdict"] = verdict
    return parsed


def build_spec_review_block(review_data, override_applied=False, override_reason=None, override_confirmed_at=None):
    """Render the top-level spec review block from parsed review data."""
    metadata = review_data.get("metadata") or {}
    verdict = review_data.get("verdict") or "incomplete"
    automated_passes = normalize_automated_passes(review_data.get("automated_passes"))
    timestamp = override_confirmed_at or metadata.get("reviewed_at") or now_iso()
    reviewer_mode = "human_override" if override_applied else (metadata.get("reviewer_mode") or "")
    reviewer_session = "" if override_applied else (metadata.get("reviewer_session") or "")
    round_status = "override" if override_applied else (metadata.get("round_status") or "")

    lines = [
        "review:",
        f"  timestamp: {json.dumps(timestamp)}",
        f"  verdict: {json.dumps(verdict)}",
        f"  review_rounds: {review_data.get('review_count', 0)}",
        f"  reviewer_mode: {json.dumps(reviewer_mode)}",
        f"  reviewer_session: {json.dumps(reviewer_session)}",
        f"  round_status: {json.dumps(round_status)}",
        f"  override_applied: {'true' if override_applied else 'false'}",
        f"  override_reason: {json.dumps(override_reason) if override_reason is not None else 'null'}",
        f"  override_confirmed_at: {json.dumps(override_confirmed_at) if override_confirmed_at is not None else 'null'}",
        "  passes:",
        f"    - id: spec_compliance\n      result: {json.dumps(automated_passes['spec_compliance'])}",
        f"    - id: scope_drift\n      result: {json.dumps(automated_passes['scope_drift'])}",
        f"    - id: adversarial_review\n      result: {json.dumps(verdict)}",
        f"  blocking_count: {len(review_data.get('blocking', []))}",
        f"  non_blocking_count: {len(review_data.get('non_blocking', []))}",
    ]
    return "\n".join(lines)


def confirm_human_override(task_id, gate_reason):
    """Require interactive confirmation before allowing a human-reviewed override."""
    if not sys.stdin.isatty():
        print(f"  {c(C_RED, 'error')}: {c(C_BOLD, '--human-reviewed')} requires an interactive terminal")
        sys.exit(1)

    print(f"  {c(C_YELLOW, 'review gate blocked')}: {gate_reason}")
    try:
        confirm = input(f"  Type '{task_id}' to confirm a human-reviewed override: ").strip()
    except EOFError:
        print(f"  {c(C_RED, 'error')}: confirmation aborted")
        sys.exit(1)

    if confirm != task_id:
        print(f"  {c(C_RED, 'error')}: confirmation failed")
        sys.exit(1)
    return now_iso()


def run_spec_compliance_check(root, text):
    """Run acceptance criteria in read-only review mode."""
    spec_cwd = None
    match = re.search(r'^\s+context:.*?\n(?:\s+\S.*\n)*?\s+cwd:\s*"?([^"\n]+)"?', text, re.MULTILINE)
    if match:
        spec_cwd = match.group(1).strip().strip('"').strip("'")

    criteria = parse_acceptance_criteria(text)
    if not criteria:
        return {"result": "pass", "lines": ["no acceptance criteria found"]}

    before = len(criteria)
    criteria = [ac for ac in criteria if ac.get("result") != "pass"]
    skipped_resume = before - len(criteria)
    runnable = [ac for ac in criteria if ac.get("command") and ac["command"] != "TODO"]
    manual = [ac for ac in criteria if not ac.get("command") or ac["command"] == "TODO"]

    if not runnable and not manual:
        lines = [f"resume: skipping {skipped_resume} already-passed criteria"] if skipped_resume else ["no runnable criteria found"]
        return {"result": "pass", "lines": lines}

    failure_lines = []
    for ac in runnable:
        ac_id = ac["id"]
        cmd = ac["command"]
        expected = ac.get("expected", "")

        effective_cwd = ac.get("cwd") or spec_cwd
        ac_cwd = root
        if effective_cwd:
            ac_cwd = (root / effective_cwd).resolve()
            if not str(ac_cwd).startswith(str(root.resolve())):
                failure_lines.append(f"{ac_id}: cwd '{effective_cwd}' escapes workspace root")
                continue
            if not ac_cwd.is_dir():
                failure_lines.append(f"{ac_id}: cwd '{effective_cwd}' not found")
                continue

        try:
            result = subprocess.run(
                cmd,
                shell=True,
                capture_output=True,
                text=True,
                timeout=120,
                cwd=str(ac_cwd),
            )
        except subprocess.TimeoutExpired:
            failure_lines.append(f"{ac_id}: command timed out after 120s")
            continue
        except Exception as e:
            failure_lines.append(f"{ac_id}: {e}")
            continue

        output = (result.stdout + result.stderr).strip()
        if not check_expected(result.returncode, output, expected):
            failure_lines.append(f"{ac_id}: exit {result.returncode}")
            if expected:
                failure_lines.append(f"{ac_id}: expected {expected}")
            for line in output.splitlines()[:3]:
                failure_lines.append(f"{ac_id}: {line}")

    if failure_lines:
        return {"result": "fail", "lines": failure_lines}

    lines = []
    if skipped_resume:
        lines.append(f"resume: skipping {skipped_resume} already-passed criteria")
    if manual:
        lines.append(f"manual criteria skipped: {len(manual)}")
    if not lines:
        lines.append("all runnable criteria passed")
    return {"result": "pass", "lines": lines}


def run_scope_drift_check(root, task_id):
    """Run scope drift in read-only review mode."""
    try:
        result = subprocess.run(
            f"trellis audit {task_id}",
            shell=True,
            capture_output=True,
            text=True,
            timeout=60,
            cwd=str(root),
        )
    except (subprocess.TimeoutExpired, Exception) as e:
        return {"result": "fail", "lines": [str(e)]}

    output = (result.stdout + result.stderr).strip()
    lines = output.splitlines()[-5:] if output else []
    if result.returncode == 0:
        return {"result": "pass", "lines": lines}
    return {"result": "fail", "lines": lines}


def collect_automated_review_passes(root, task_id, text):
    """Collect the current automated review pass states without mutating the spec."""
    compliance = run_spec_compliance_check(root, text)
    scope_drift = run_scope_drift_check(root, task_id)
    return normalize_automated_passes({
        "spec_compliance": compliance["result"],
        "scope_drift": scope_drift["result"],
    })


def validate_spec(root, spec):
    """Validate a spec against the JSON schema. Returns list of errors (empty = valid)."""
    schema_path = root / SCHEMA_PATH
    if not schema_path.exists():
        return [f"schema not found at {SCHEMA_PATH}"]

    try:
        schema = json.loads(schema_path.read_text())
    except json.JSONDecodeError as e:
        return [f"invalid schema JSON: {e}"]

    text = spec.read_text()
    errors = []

    required_top = schema.get("required", [])
    for field in required_top:
        if not yaml_read_field(text, field):
            if not re.search(rf'^{field}:', text, re.MULTILINE):
                errors.append(f"missing required field: {field}")

    task_id = yaml_read_field(text, "task_id")
    if task_id and not re.match(r'^[a-z0-9-]+$', task_id):
        errors.append(f"task_id must be kebab-case: got '{task_id}'")

    status = yaml_read_field(text, "status")
    valid_statuses = ["draft", "blocked", "under_review", "approved", "in_progress",
                      "completed", "failed", "cancelled"]
    if status and status not in valid_statuses:
        errors.append(f"invalid status: '{status}' (expected one of: {', '.join(valid_statuses)})")

    sv = yaml_read_field(text, "spec_version")
    if sv and not re.match(r'^\d+\.\d+$', sv):
        errors.append(f"spec_version must be semver: got '{sv}'")

    if not re.search(r'^phases:', text, re.MULTILINE):
        errors.append("missing required field: phases")
    else:
        phase_ids = re.findall(r'^\s+-\s+id:\s*"?(phase\d+)"?', text, re.MULTILINE)
        if not phase_ids:
            errors.append("phases array is empty (at least 1 phase required)")

    if not re.search(r'^planning_log:', text, re.MULTILINE):
        errors.append("missing required field: planning_log")

    if re.search(r'^task:', text, re.MULTILINE):
        task_required = ["title", "summary", "size", "risk_level"]
        for field in task_required:
            if not yaml_read_nested(text, "task", field):
                errors.append(f"missing required task field: task.{field}")
    else:
        errors.append("missing required field: task")

    # Check for TODO placeholders in actionable fields
    todo_patterns = [
        (r'^\s+(?:command|content_spec|description|file):\s*"?TODO', "has TODO placeholder"),
        (r'^\s+-\s+"?TODO', "has TODO list item"),
    ]
    for pattern, msg in todo_patterns:
        matches = re.findall(pattern, text, re.MULTILINE)
        if matches:
            errors.append(f"{msg} ({len(matches)} occurrence{'s' if len(matches) > 1 else ''})")
            break  # One error is enough

    return errors


def cmd_validate(args):
    """Validate a spec against the JSON schema."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    rel = spec.relative_to(root)
    text = spec.read_text()

    errors = validate_spec(root, spec)

    if errors:
        print(f"{c(C_RED, 'FAIL')}: {rel}")
        for e in errors:
            print(f"  - {e}")
        sys.exit(1)
    else:
        sv = yaml_read_field(text, "spec_version")
        task_id = yaml_read_field(text, "task_id")
        status = yaml_read_field(text, "status")
        print(f"{c(C_GREEN, 'PASS')}: {rel}")
        print(f"  spec_version: {sv}")
        print(f"  task_id: {task_id}")
        print(f"  status: {status}")
        total, completed, failed, in_prog = count_phases(text)
        print(f"  phases: {total}")


def parse_yaml_value(raw):
    """Parse a YAML scalar value, handling quotes and escapes."""
    v = raw.strip()
    if not v:
        return ""
    # Double-quoted: unescape \"
    if v.startswith('"') and v.endswith('"'):
        return v[1:-1].replace('\\"', '"')
    # Single-quoted
    if v.startswith("'") and v.endswith("'"):
        return v[1:-1].replace("''", "'")
    return v


def parse_acceptance_criteria(text):
    """Extract acceptance criteria from all phases using indent-aware parsing."""
    criteria = []
    lines = text.splitlines()
    current_phase = None
    i = 0

    while i < len(lines):
        line = lines[i]

        # Track phase id - matches both "- id: phase1" and "- id: \"phase1\""
        m = re.match(r'^(\s+)-\s+id:\s*(.+)$', line)
        if m:
            val = parse_yaml_value(m.group(2))
            if re.match(r'^phase\d+$', val):
                current_phase = val
                i += 1
                continue

        # Enter acceptance_criteria or validation block (under a phase)
        if current_phase and re.match(r'^(\s+)(acceptance_criteria|validation)\s*:', line):
            block_indent = len(line) - len(line.lstrip())
            i += 1
            # Parse list items in this block
            while i < len(lines):
                item_line = lines[i]
                # Empty line - skip
                if not item_line.strip():
                    i += 1
                    continue
                item_indent = len(item_line) - len(item_line.lstrip())
                # Dedented past block - exit
                if item_indent <= block_indent and item_line.strip():
                    break
                # List item start: "- id: ..." or "- dod_id: ..."
                m = re.match(r'^(\s+)-\s+(id|dod_id):\s*(.+)$', item_line)
                if m:
                    item_base_indent = len(m.group(1))
                    ac = {"id": parse_yaml_value(m.group(3)), "phase": current_phase}
                    i += 1
                    # Read fields for this item
                    while i < len(lines):
                        field_line = lines[i]
                        if not field_line.strip():
                            i += 1
                            continue
                        fi = len(field_line) - len(field_line.lstrip())
                        # Dedented to item level or less - done with this item
                        if fi <= item_base_indent and field_line.strip():
                            break
                        # New list item at same level
                        if field_line.strip().startswith('- ') and fi == item_base_indent:
                            break
                        # Parse key: value
                        fm = re.match(r'^\s+([\w_]+):\s*(.*)$', field_line)
                        if fm:
                            key = fm.group(1)
                            if key in ("type", "description", "command", "expected", "cwd", "result"):
                                ac[key] = parse_yaml_value(fm.group(2))
                        i += 1
                    criteria.append(ac)
                else:
                    i += 1
            continue

        i += 1

    return criteria


def record_exec_result(text, ac_id, passed, output_snippet=""):
    """Record execution result for an acceptance criterion in the spec."""
    lines = text.splitlines(True)
    result = []
    i = 0
    while i < len(lines):
        line = lines[i]
        # Match the id line for this criterion (id: or dod_id:)
        if re.search(rf'(?:id|dod_id):\s*"?{re.escape(ac_id)}"?\s*$', line):
            result.append(line)
            # Determine the indent for sibling fields
            item_match = re.match(r'^(\s+)-\s+', line)
            if item_match:
                field_indent = ' ' * (len(item_match.group(1)) + 2)
            else:
                field_indent = ' ' * (len(line) - len(line.lstrip()))
            i += 1
            # Copy existing fields, skip old result/executed_at/result_output
            while i < len(lines):
                fl = lines[i]
                if not fl.strip():
                    break
                fi = len(fl) - len(fl.lstrip())
                expected_fi = len(field_indent)
                # Dedented or new list item - done
                if fi < expected_fi:
                    break
                if fi == expected_fi - 2 and fl.strip().startswith('- '):
                    break
                if re.match(r'^\s+(result|result_output|executed_at):', fl):
                    i += 1
                    continue
                result.append(fl)
                i += 1
            # Append new result fields
            result.append(f'{field_indent}result: "{"pass" if passed else "fail"}"\n')
            result.append(f'{field_indent}executed_at: "{now_iso()}"\n')
            if output_snippet:
                snippet = output_snippet[:200].replace('"', '\\"').replace('\n', ' ')
                result.append(f'{field_indent}result_output: "{snippet}"\n')
            continue
        result.append(line)
        i += 1

    return ''.join(result)


def check_expected(returncode, output, expected):
    """Check command result against expected outcome.

    Handles common patterns:
      "exit code 0"          → check returncode
      "0 failures"           → search output for "0 failures" (and reject N failures where N>0)
      "no matches"           → pass if output is empty or command returned non-zero
      "Syntax OK"            → search output for literal string
      any other string       → search output for literal match (case-insensitive)
      empty/missing          → fall back to exit code 0
    """
    if not expected:
        return returncode == 0

    exp = expected.strip()
    exp_lower = exp.lower()

    # "no matches" — pass when output is empty
    if exp_lower == "no matches":
        return returncode != 0 or not output

    # "exit code N"
    m = re.match(r'^exit\s+code\s+(\d+)$', exp_lower)
    if m:
        return returncode == int(m.group(1))

    # "0 failures" — check exit code AND that output doesn't contain "N failures" where N > 0
    if exp_lower == "0 failures":
        if returncode != 0:
            return False
        # Look for rspec/test patterns like "2 failures" or "1 failure"
        fail_match = re.search(r'(\d+)\s+failures?', output)
        if fail_match and int(fail_match.group(1)) > 0:
            return False
        return True

    # Literal substring match (case-insensitive) — "Syntax OK", "success", etc.
    if returncode != 0:
        return False
    return exp_lower in output.lower()


def cmd_exec(args):
    """Run acceptance criteria commands and record results."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    status = yaml_read_field(text, "status")
    if status not in ("in_progress", "approved"):
        print(f"{c(C_RED, 'error')}: spec must be in_progress or approved to exec (current: {status})")
        sys.exit(1)

    # Spec-level default cwd (task.context.cwd) — used when criterion has no cwd
    spec_cwd = None
    m = re.search(r'^\s+context:.*?\n(?:\s+\S.*\n)*?\s+cwd:\s*"?([^"\n]+)"?', text, re.MULTILINE)
    if m:
        spec_cwd = m.group(1).strip().strip('"').strip("'")

    criteria = parse_acceptance_criteria(text)
    if not criteria:
        print(f"{c(C_YELLOW, 'warn')}: no acceptance criteria found in spec")
        return

    # Filter by phase if specified
    if args.phase:
        criteria = [ac for ac in criteria if ac.get("phase") == args.phase]
        if not criteria:
            print(f"{c(C_YELLOW, 'warn')}: no criteria found for phase {args.phase}")
            return

    # Resume mode: skip criteria that already passed
    skipped_resume = 0
    if args.resume:
        before = len(criteria)
        criteria = [ac for ac in criteria if ac.get("result") != "pass"]
        skipped_resume = before - len(criteria)

    # Filter to only runnable criteria (have a command)
    runnable = [ac for ac in criteria if ac.get("command") and ac["command"] != "TODO"]
    manual = [ac for ac in criteria if not ac.get("command") or ac["command"] == "TODO"]

    if not runnable and not manual and not skipped_resume:
        print(f"{c(C_YELLOW, 'warn')}: no criteria found")
        return

    print(f"{c(C_BOLD, f'Executing acceptance criteria for {args.task_id}')}")
    if args.phase:
        print(f"  phase: {args.phase}")
    if skipped_resume:
        print(f"  {c(C_DIM, f'resume: skipping {skipped_resume} already-passed criteria')}")
    print()

    passed = 0
    failed = 0
    skipped = 0

    for ac in runnable:
        ac_id = ac["id"]
        cmd = ac["command"]
        expected = ac.get("expected", "")
        desc = ac.get("description", ac_id)

        print(f"  {c(C_CYAN, ac_id)}: {desc}")

        # Resolve working directory: criterion cwd > spec-level cwd > workspace root
        effective_cwd = ac.get("cwd") or spec_cwd
        ac_cwd = root
        if effective_cwd:
            ac_cwd = (root / effective_cwd).resolve()
            if not str(ac_cwd).startswith(str(root.resolve())):
                print(f"    {c(C_RED, 'ERROR')}: cwd '{effective_cwd}' escapes workspace root")
                text = record_exec_result(text, ac_id, False, f"cwd '{effective_cwd}' escapes workspace root")
                failed += 1
                continue
            if not ac_cwd.is_dir():
                print(f"    {c(C_RED, 'ERROR')}: cwd '{effective_cwd}' is not a directory")
                text = record_exec_result(text, ac_id, False, f"cwd '{effective_cwd}' not found")
                failed += 1
                continue
            cwd_suffix = f"  {c(C_DIM, '(in ' + effective_cwd + '/)')}"
        else:
            cwd_suffix = ""
        print(f"    $ {c(C_DIM, cmd)}{cwd_suffix}")

        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True,
                timeout=120, cwd=str(ac_cwd),
            )
            output = (result.stdout + result.stderr).strip()

            # Determine pass/fail
            ac_passed = check_expected(result.returncode, output, expected)

            if ac_passed:
                print(f"    {c(C_GREEN, 'PASS')}")
                passed += 1
            else:
                print(f"    {c(C_RED, 'FAIL')} (exit code {result.returncode})")
                if expected:
                    print(f"    expected: {c(C_DIM, expected)}")
                if output:
                    for line in output.splitlines()[:5]:
                        print(f"    {c(C_DIM, line)}")
                failed += 1

            text = record_exec_result(text, ac_id, ac_passed, output[:200])

        except subprocess.TimeoutExpired:
            print(f"    {c(C_RED, 'TIMEOUT')} (120s)")
            text = record_exec_result(text, ac_id, False, "Command timed out after 120s")
            failed += 1
        except Exception as e:
            print(f"    {c(C_RED, 'ERROR')}: {e}")
            text = record_exec_result(text, ac_id, False, str(e))
            failed += 1

    for ac in manual:
        ac_id = ac["id"]
        desc = ac.get("description", ac_id)
        print(f"  {c(C_DIM, ac_id)}: {desc} (manual - skipped)")
        skipped += 1

    # Write results back
    spec.write_text(text)

    print()
    summary_parts = []
    if passed or skipped_resume:
        total_pass = passed + skipped_resume
        label = f"{total_pass} passed"
        if skipped_resume:
            label += f" ({skipped_resume} prior)"
        summary_parts.append(c(C_GREEN, label))
    if failed:
        summary_parts.append(c(C_RED, f"{failed} failed"))
    if skipped:
        summary_parts.append(c(C_DIM, f"{skipped} manual"))
    print(f"  {' / '.join(summary_parts)}")

    if failed:
        sys.exit(1)


def cmd_audit(args):
    """Compare spec changes against actual git diff to detect scope creep."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    text = spec.read_text()

    # Extract declared files from phases[*].changes[*].file
    declared = set()
    for m in re.finditer(r'^\s+file:\s*"?([^"\n]+)"?', text, re.MULTILINE):
        f = m.group(1).strip()
        if f != "TODO":
            declared.add(f)

    if not declared:
        print(f"{c(C_YELLOW, 'warn')}: no files declared in spec phases")
        return

    # Get actual changed files from git
    base_ref = args.base or "HEAD~1"
    try:
        result = subprocess.run(
            ["git", "diff", "--name-only", base_ref],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.returncode != 0:
            # Try diffing against main/master
            for branch in ("main", "master"):
                result = subprocess.run(
                    ["git", "diff", "--name-only", branch],
                    capture_output=True, text=True, cwd=str(root),
                )
                if result.returncode == 0:
                    base_ref = branch
                    break
            else:
                print(f"{c(C_RED, 'error')}: git diff failed. Use --base to specify a ref.")
                sys.exit(1)

        actual = set(line.strip() for line in result.stdout.splitlines() if line.strip())
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)

    if not actual:
        print(f"{c(C_DIM, 'No files changed in git diff')}")
        return

    print(f"{c(C_BOLD, f'Audit: {args.task_id}')} (vs {base_ref})")
    print()

    # Scope creep: files changed but not in spec
    undeclared = actual - declared
    # Missing: files in spec but not changed
    missing = declared - actual
    # Matched
    matched = declared & actual

    if matched:
        print(f"  {c(C_GREEN, 'Declared & changed')} ({len(matched)}):")
        for f in sorted(matched):
            print(f"    {c(C_GREEN, '✓')} {f}")

    if undeclared:
        print(f"\n  {c(C_RED, 'Scope creep - changed but not in spec')} ({len(undeclared)}):")
        for f in sorted(undeclared):
            print(f"    {c(C_RED, '!')} {f}")

    if missing:
        print(f"\n  {c(C_YELLOW, 'In spec but not changed')} ({len(missing)}):")
        for f in sorted(missing):
            print(f"    {c(C_YELLOW, '?')} {f}")

    print()
    if undeclared:
        pct = len(undeclared) / len(actual) * 100
        print(f"  {c(C_RED, f'Scope drift: {pct:.0f}%')} ({len(undeclared)}/{len(actual)} files undeclared)")
        sys.exit(1)
    else:
        print(f"  {c(C_GREEN, 'Clean')} - all changes match spec")


def cmd_diff(args):
    """Show git diff for a spec file."""
    root = require_root()
    spec = require_spec(root, args.task_id)
    rel = spec.relative_to(root)

    try:
        result = subprocess.run(
            ["git", "log", "--oneline", "-10", "--follow", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if result.stdout.strip():
            print(f"{c(C_BOLD, f'History: {rel}')}")
            print(result.stdout)
        else:
            print(f"{c(C_DIM, 'No git history for this spec')}")

        # Show diff if uncommitted changes exist
        diff_result = subprocess.run(
            ["git", "diff", "--", str(rel)],
            capture_output=True, text=True, cwd=str(root),
        )
        if diff_result.stdout.strip():
            print(f"{c(C_BOLD, 'Uncommitted changes:')}")
            print(diff_result.stdout)
    except FileNotFoundError:
        print(f"{c(C_RED, 'error')}: git not found")
        sys.exit(1)


def cmd_report(args):
    """Aggregate stats across archived specs."""
    root = require_root()
    specs = find_all_specs(root)

    if not specs:
        print(f"{c(C_DIM, 'No specs found.')}")
        return

    # Collect stats
    total = 0
    by_status = {}
    by_month = {}
    sizes = {}
    risks = {}
    self_eval_scores = []
    exec_pass = 0
    exec_fail = 0
    exec_total = 0
    specs_with_exec = 0
    specs_without_exec = 0
    phase_counts = []

    for spec_path, label in specs:
        text = spec_path.read_text()
        total += 1

        status = yaml_read_field(text, "status") or "unknown"
        by_status[status] = by_status.get(status, 0) + 1

        # Month grouping from label
        if label.startswith("archive/"):
            month = label.split("/", 1)[1]
            by_month[month] = by_month.get(month, 0) + 1

        size = yaml_read_nested(text, "task", "size") or "unknown"
        sizes[size] = sizes.get(size, 0) + 1

        risk = yaml_read_nested(text, "task", "risk_level") or "unknown"
        risks[risk] = risks.get(risk, 0) + 1

        # Self-eval scores
        score_match = re.search(r'total:\s*(\d+)', text)
        if score_match:
            self_eval_scores.append(int(score_match.group(1)))

        # Exec results
        passes = len(re.findall(r'result:\s*"?pass"?', text))
        fails = len(re.findall(r'result:\s*"?fail"?', text))
        if passes or fails:
            exec_pass += passes
            exec_fail += fails
            exec_total += passes + fails
            specs_with_exec += 1
        else:
            specs_without_exec += 1

        # Phase counts
        t, _, _, _ = count_phases(text)
        if t > 0:
            phase_counts.append(t)

    # Print report
    print(f"{c(C_BOLD, 'Trellis Report')}")
    print(f"  {total} total specs")
    print()

    # Status breakdown
    print(f"{c(C_BOLD, 'By status:')}")
    for status in ["completed", "failed", "cancelled", "in_progress", "approved", "draft"]:
        count = by_status.get(status, 0)
        if count:
            color = STATUS_COLORS.get(status, "")
            pct = count / total * 100
            bar = "#" * int(pct / 2)
            print(f"  {c(color, f'{status:14s}')} {count:4d}  {pct:5.1f}%  {c(C_DIM, bar)}")
    print()

    # Monthly activity
    if by_month:
        print(f"{c(C_BOLD, 'By month:')}")
        for month in sorted(by_month.keys(), reverse=True)[:6]:
            print(f"  {month}  {by_month[month]:3d} specs")
        print()

    # Size/risk distribution
    if any(v != "unknown" for v in sizes):
        print(f"{c(C_BOLD, 'Sizes:')}  ", end="")
        print("  ".join(f"{s}: {sizes.get(s, 0)}" for s in ["micro", "small", "medium", "large"] if sizes.get(s, 0)))
        print(f"{c(C_BOLD, 'Risks:')}  ", end="")
        print("  ".join(f"{r}: {risks.get(r, 0)}" for r in ["low", "medium", "high"] if risks.get(r, 0)))
        print()

    # Self-eval stats
    if self_eval_scores:
        avg = sum(self_eval_scores) / len(self_eval_scores)
        perfect = sum(1 for s in self_eval_scores if s == 10)
        below_7 = sum(1 for s in self_eval_scores if s < 7)
        print(f"{c(C_BOLD, 'Self-eval:')}")
        print(f"  avg: {avg:.1f}/10  ({len(self_eval_scores)} scored)")
        if perfect:
            pct = perfect / len(self_eval_scores) * 100
            color = C_YELLOW if pct > 50 else C_DIM
            print(f"  {c(color, f'perfect 10s: {perfect} ({pct:.0f}%)')}")
        if below_7:
            print(f"  below threshold: {below_7}")
        print()

    # Exec results
    if exec_total:
        pass_rate = exec_pass / exec_total * 100
        print(f"{c(C_BOLD, 'Exec results:')}")
        print(f"  {c(C_GREEN, f'{exec_pass} passed')} / {c(C_RED, f'{exec_fail} failed')}  ({pass_rate:.0f}% pass rate)")
        print(f"  {specs_with_exec} specs with results, {specs_without_exec} without")
        print()

    # Phase stats
    if phase_counts:
        avg_phases = sum(phase_counts) / len(phase_counts)
        print(f"{c(C_BOLD, 'Phases:')}  avg {avg_phases:.1f} per spec, range {min(phase_counts)}-{max(phase_counts)}")
        print()


def cmd_version(args):
    print(f"trellis {VERSION}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="trellis",
        description="Spec-driven development framework for AI coding agents",
    )
    parser.add_argument("--version", action="store_true", help="Show version")
    sub = parser.add_subparsers(dest="command")

    # init
    p_init = sub.add_parser("init", help="Bootstrap Trellis workspace")

    # new
    p_new = sub.add_parser("new", help="Create a new spec from template")
    p_new.add_argument("task_id", help="Task ID (kebab-case)")
    p_new.add_argument("-t", "--title", help="Task title")
    p_new.add_argument("-s", "--size", choices=["micro", "small", "medium", "large"])
    p_new.add_argument("-r", "--risk", choices=["low", "medium", "high"])

    # status
    p_status = sub.add_parser("status", help="Show spec status")
    p_status.add_argument("task_id", help="Task ID")

    # list
    p_list = sub.add_parser("list", help="List all specs")
    p_list.add_argument("filter", nargs="?", help="Filter by status or search term")

    # approve
    p_approve = sub.add_parser("approve", help="Approve a draft spec")
    p_approve.add_argument("task_id", help="Task ID")

    # start
    p_start = sub.add_parser("start", help="Start execution of approved spec")
    p_start.add_argument("task_id", help="Task ID")

    # review
    p_review = sub.add_parser("review", help="Run review passes and generate adversarial review prompt")
    p_review.add_argument("task_id", help="Task ID")

    # complete
    p_complete = sub.add_parser("complete", help="Mark spec as completed")
    p_complete.add_argument("task_id", help="Task ID")
    p_complete.add_argument("--human-reviewed", action="store_true", help="Allow a human-confirmed override when the review gate is blocked")
    p_complete.add_argument("--reason", help="Required with --human-reviewed; records why the override was applied")

    # fail
    p_fail = sub.add_parser("fail", help="Mark spec as failed")
    p_fail.add_argument("task_id", help="Task ID")

    # cancel
    p_cancel = sub.add_parser("cancel", help="Cancel a spec")
    p_cancel.add_argument("task_id", help="Task ID")

    # validate
    p_validate = sub.add_parser("validate", help="Validate spec against schema")
    p_validate.add_argument("task_id", help="Task ID")

    # exec
    p_exec = sub.add_parser("exec", help="Run acceptance criteria and record results")
    p_exec.add_argument("task_id", help="Task ID")
    p_exec.add_argument("-p", "--phase", help="Run only criteria for this phase (e.g. phase1)")
    p_exec.add_argument("-r", "--resume", action="store_true", help="Skip criteria that already passed")

    # audit
    p_audit = sub.add_parser("audit", help="Check spec changes vs actual git diff")
    p_audit.add_argument("task_id", help="Task ID")
    p_audit.add_argument("-b", "--base", help="Git base ref (default: HEAD~1)")

    # diff
    p_diff = sub.add_parser("diff", help="Show git history and changes for a spec")
    p_diff.add_argument("task_id", help="Task ID")

    # report
    p_report = sub.add_parser("report", help="Aggregate stats across all specs")

    args = parser.parse_args()

    if args.version:
        cmd_version(args)
        return

    commands = {
        "init": cmd_init,
        "new": cmd_new,
        "status": cmd_status,
        "list": cmd_list,
        "approve": cmd_approve,
        "start": cmd_start,
        "review": cmd_review,
        "complete": cmd_complete,
        "fail": cmd_fail,
        "cancel": cmd_cancel,
        "validate": cmd_validate,
        "exec": cmd_exec,
        "audit": cmd_audit,
        "diff": cmd_diff,
        "report": cmd_report,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
