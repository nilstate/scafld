def now_iso():
    return datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).strftime("%Y-%m-%dT%H:%M:%SZ")


def deep_merge(base, overlay):
    """Deep merge overlay dict into base dict. Overlay wins on conflicts."""
    result = dict(base)
    for key, val in overlay.items():
        if key in result and isinstance(result[key], dict) and isinstance(val, dict):
            result[key] = deep_merge(result[key], val)
        else:
            result[key] = val
    return result


def simple_yaml_load(text):
    """Minimal YAML loader for config files (handles scalars and nested dicts).

    Not a full YAML parser - handles the subset used in config.yaml:
    key: value, nested dicts, and simple lists. Good enough for config overlay.
    """
    result = {}
    stack = [(result, -1)]  # (dict, indent_level)

    for line in text.splitlines():
        # Skip comments and blank lines
        stripped = line.strip()
        if not stripped or stripped.startswith('#'):
            continue

        # Calculate indent
        indent = len(line) - len(line.lstrip())

        # Pop stack to find parent at correct indent level
        while len(stack) > 1 and stack[-1][1] >= indent:
            stack.pop()

        current_dict = stack[-1][0]

        # List item: "- value"
        if stripped.startswith('- '):
            # We don't need full list support for config overlay
            continue

        # Key: value
        m = re.match(r'^(\s*)([\w_.-]+)\s*:\s*(.*?)$', line)
        if not m:
            continue

        key = m.group(2)
        raw_val = m.group(3).strip()

        if raw_val == '' or raw_val.startswith('#'):
            # Nested dict - create child
            child = {}
            current_dict[key] = child
            stack.append((child, indent))
        else:
            # Scalar value
            current_dict[key] = parse_yaml_value(raw_val)

    return result


def load_config(root):
    """Load config with local overlay support."""
    config = {}

    # Load base config
    base_path = root / CONFIG_PATH
    if base_path.exists():
        try:
            config = simple_yaml_load(base_path.read_text())
        except Exception:
            pass

    # Merge local overlay
    local_path = root / CONFIG_LOCAL_PATH
    if local_path.exists():
        try:
            local = simple_yaml_load(local_path.read_text())
            config = deep_merge(config, local)
        except Exception:
            pass

    return config


def find_root():
    """Walk up from cwd to find the project root (contains .ai/ dir)."""
    d = Path.cwd()
    while d != d.parent:
        if (d / AI_DIR).is_dir():
            return d
        d = d.parent
    return None


def yaml_read_field(text, field):
    """Read a top-level YAML scalar field (simple regex, no library needed)."""
    m = re.search(rf'^{field}:\s*"?([^"\n]+)"?', text, re.MULTILINE)
    if m:
        return m.group(1).strip().strip('"').strip("'")
    return None


def yaml_set_field(text, field, value):
    """Set a top-level YAML scalar field."""
    quoted = f'"{value}"'
    new_text, n = re.subn(
        rf'^{field}:\s*.*$',
        f'{field}: {quoted}',
        text, count=1, flags=re.MULTILINE,
    )
    if n == 0:
        # Field not found - add after spec_version or at top
        new_text = f'{field}: {quoted}\n' + text
    return new_text


def yaml_read_nested(text, parent, field):
    """Read a field nested one level under a parent block."""
    in_parent = False
    for line in text.splitlines():
        if re.match(rf'^{parent}:', line):
            in_parent = True
            continue
        if in_parent:
            if line and not line[0].isspace():
                break
            m = re.match(rf'^\s+{field}:\s*"?([^"\n]+)"?', line)
            if m:
                return m.group(1).strip().strip('"').strip("'")
    return None


def count_phases(text):
    """Count phases and their statuses."""
    total = 0
    completed = 0
    failed = 0
    in_progress = 0
    for m in re.finditer(r'^\s+-\s+id:\s*"?phase\d+"?', text, re.MULTILINE):
        total += 1
    for m in re.finditer(r'^\s+status:\s*"?completed"?', text, re.MULTILINE):
        completed += 1
    for m in re.finditer(r'^\s+status:\s*"?failed"?', text, re.MULTILINE):
        failed += 1
    for m in re.finditer(r'^\s+status:\s*"?in_progress"?', text, re.MULTILINE):
        in_progress += 1
    # Subtract the top-level status from phase counts
    top_status = yaml_read_field(text, "status")
    if top_status == "completed":
        completed = max(0, completed - 1)
    elif top_status == "failed":
        failed = max(0, failed - 1)
    elif top_status == "in_progress":
        in_progress = max(0, in_progress - 1)
    return total, completed, failed, in_progress


def find_specs(root, task_id):
    """Find all spec files across all directories."""
    specs = []
    for folder in [DRAFTS_DIR, APPROVED_DIR, ACTIVE_DIR]:
        p = root / folder / f"{task_id}.yaml"
        if p.exists():
            specs.append(p)
    # Search archive
    archive = root / ARCHIVE_DIR
    if archive.is_dir():
        for month_dir in sorted(archive.iterdir(), reverse=True):
            if month_dir.is_dir():
                p = month_dir / f"{task_id}.yaml"
                if p.exists():
                    specs.append(p)
    return specs


def find_spec(root, task_id):
    """Find the first spec file across all directories. Returns Path or None."""
    specs = find_specs(root, task_id)
    return specs[0] if specs else None


def find_all_specs(root):
    """Find all spec files. Returns list of (Path, folder_type)."""
    specs = []
    for label, folder in [("drafts", DRAFTS_DIR), ("approved", APPROVED_DIR), ("active", ACTIVE_DIR)]:
        d = root / folder
        if d.is_dir():
            for f in sorted(d.glob("*.yaml")):
                specs.append((f, label))
    archive = root / ARCHIVE_DIR
    if archive.is_dir():
        for month_dir in sorted(archive.iterdir(), reverse=True):
            if month_dir.is_dir():
                for f in sorted(month_dir.glob("*.yaml")):
                    specs.append((f, f"archive/{month_dir.name}"))
    return specs


def append_planning_log(text, summary, actor="cli"):
    """Append a planning_log entry to the spec text."""
    entry = f'  - timestamp: "{now_iso()}"\n    actor: "{actor}"\n    summary: "{summary}"'
    # Find planning_log section and append
    if re.search(r'^planning_log:', text, re.MULTILINE):
        # Find the last entry or the planning_log line itself
        # Insert before the next top-level key after planning_log
        lines = text.splitlines(True)
        insert_idx = None
        in_log = False
        for i, line in enumerate(lines):
            if re.match(r'^planning_log:', line):
                in_log = True
                continue
            if in_log:
                if line.strip() and not line[0].isspace():
                    insert_idx = i
                    break
        if insert_idx is None:
            # planning_log is at end of file
            text = text.rstrip('\n') + '\n' + entry + '\n'
        else:
            lines.insert(insert_idx, entry + '\n')
            text = ''.join(lines)
    else:
        text += f'\nplanning_log:\n{entry}\n'
    return text


def move_spec(root, spec_path, new_status):
    """Move spec to the correct folder and update status + timestamp."""
    text = spec_path.read_text()
    current_status = yaml_read_field(text, "status")

    # Validate transition
    allowed = VALID_TRANSITIONS.get(current_status, [])
    if new_status not in allowed:
        print(f"{c(C_RED, 'error')}: cannot transition from '{current_status}' to '{new_status}'")
        print(f"  allowed transitions: {', '.join(allowed) if allowed else 'none'}")
        sys.exit(1)

    # Update fields
    text = yaml_set_field(text, "status", new_status)
    text = yaml_set_field(text, "updated", now_iso())

    # Auto-append planning_log entry
    action_labels = {
        "approved": "Spec approved",
        "in_progress": "Execution started",
        "completed": "Spec completed",
        "failed": "Spec marked failed",
        "cancelled": "Spec cancelled",
    }
    text = append_planning_log(text, action_labels.get(new_status, f"Status changed to {new_status}"))

    # Determine destination
    if new_status in ("completed", "failed", "cancelled"):
        month = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m")
        dest_dir = root / ARCHIVE_DIR / month
    else:
        dest_dir = root / STATUS_FOLDERS[new_status]

    dest_dir.mkdir(parents=True, exist_ok=True)
    dest = dest_dir / spec_path.name

    spec_path.write_text(text)
    shutil.move(str(spec_path), str(dest))

    rel_from = spec_path.relative_to(root)
    rel_to = dest.relative_to(root)
    print(f"{c(C_GREEN, '  moved')}: {rel_from} -> {rel_to}")
    print(f" {c(C_DIM, 'status')}: {c(STATUS_COLORS.get(new_status, ''), new_status)}")
    return dest


def require_root():
    root = find_root()
    if not root:
        print(f"{c(C_RED, 'error')}: not in a Trellis project (no .ai/ directory found)")
        print(f"  run '{c(C_BOLD, 'trellis init')}' to set up a workspace")
        sys.exit(1)
    return root


def require_spec(root, task_id):
    specs = find_specs(root, task_id)
    if not specs:
        print(f"{c(C_RED, 'error')}: spec not found: {task_id}")
        print(f"  searched: {DRAFTS_DIR}/, {APPROVED_DIR}/, {ACTIVE_DIR}/, {ARCHIVE_DIR}/")
        sys.exit(1)
    if len(specs) > 1:
        print(f"{c(C_RED, 'error')}: ambiguous task-id: {task_id}")
        print("  matching specs:")
        for spec in specs:
            print(f"    - {spec.relative_to(root)}")
        print("  resolve the duplicate task-id before continuing")
        sys.exit(1)
    return specs[0]


def collect_changed_files(text):
    """Collect unique changed files declared in spec phases."""
    return sorted(set(re.findall(r'^\s+-\s+file:\s*"?([^"\n]+)"?', text, re.MULTILINE)))


def normalize_automated_passes(raw_passes=None):
    """Normalize automated pass values to pass/fail/not_run."""
    normalized = {"spec_compliance": "not_run", "scope_drift": "not_run"}
    for key, value in (raw_passes or {}).items():
        if key not in normalized:
            continue
        if isinstance(value, bool):
            normalized[key] = "pass" if value else "fail"
        elif isinstance(value, str) and value in REVIEW_PASS_VALUES:
            normalized[key] = value
    return normalized


def review_pass_label(value):
    """Human label for automated pass values."""
    return {
        "pass": "PASS",
        "fail": "FAIL",
        "not_run": "NOT RUN",
    }.get(value, str(value).upper())


def build_review_metadata(reviewer_mode, round_status, automated_passes, reviewer_session="", override_reason=None):
    """Build Review Artifact v2 metadata."""
    return {
        "schema_version": REVIEW_SCHEMA_VERSION,
        "round_status": round_status,
        "reviewer_mode": reviewer_mode,
        "reviewer_session": reviewer_session,
        "reviewed_at": now_iso(),
        "override_reason": override_reason,
        "automated_passes": normalize_automated_passes(automated_passes),
    }


def validate_review_metadata(metadata):
    """Validate Review Artifact v2 metadata. Returns list of errors."""
    if not isinstance(metadata, dict):
        return ["metadata is not an object"]

    errors = []
    if metadata.get("schema_version") != REVIEW_SCHEMA_VERSION:
        errors.append(f"schema_version must be {REVIEW_SCHEMA_VERSION}")
    if metadata.get("round_status") not in REVIEW_ROUND_STATUSES:
        errors.append("round_status must be completed or override")
    if metadata.get("reviewer_mode") not in REVIEWER_MODES:
        errors.append("reviewer_mode is invalid")
    if not isinstance(metadata.get("reviewer_session"), str):
        errors.append("reviewer_session must be a string")
    if not isinstance(metadata.get("reviewed_at"), str) or not metadata.get("reviewed_at"):
        errors.append("reviewed_at must be a non-empty string")
    override_reason = metadata.get("override_reason")
    if override_reason is not None and not isinstance(override_reason, str):
        errors.append("override_reason must be a string or null")

    automated_passes = metadata.get("automated_passes")
    if not isinstance(automated_passes, dict):
        errors.append("automated_passes must be an object")
    else:
        for key in ("spec_compliance", "scope_drift"):
            if automated_passes.get(key) not in REVIEW_PASS_VALUES:
                errors.append(f"automated_passes.{key} must be pass, fail, or not_run")

    if metadata.get("round_status") == "override":
        if metadata.get("reviewer_mode") != "human_override":
            errors.append("override round must use reviewer_mode=human_override")
        if not isinstance(override_reason, str) or not override_reason.strip():
            errors.append("override round must include a non-empty override_reason")

    return errors


def render_review_automated_passes(pass_states):
    """Render the human-readable automated passes section."""
    normalized = normalize_automated_passes(pass_states)
    return "\n".join(
        f"- {name}: {review_pass_label(result)}"
        for name, result in normalized.items()
    )


def ensure_review_file_header(review_file, task_id, spec_text):
    """Create the shared review file header if it does not exist yet."""
    if review_file.exists():
        return

    task_title = yaml_read_nested(spec_text, "task", "title") or task_id
    task_summary = yaml_read_nested(spec_text, "task", "summary") or ""
    changed_files = collect_changed_files(spec_text)
    files_section = "\n".join(f"- {path}" for path in changed_files) if changed_files else "- (see git diff)"

    review_file.parent.mkdir(parents=True, exist_ok=True)
    review_file.write_text(f"""# Review: {task_id}

## Spec
{task_title}
{task_summary}

## Files Changed
{files_section}
""")


def append_review_round(review_file, task_id, spec_text, metadata, verdict="", blocking=None, non_blocking=None):
    """Append a review round using Review Artifact v2."""
    ensure_review_file_header(review_file, task_id, spec_text)

    existing_text = review_file.read_text()
    review_count = len(re.findall(r'^## Review \d+\s+—', existing_text, re.MULTILINE)) + 1
    metadata_json = json.dumps(metadata, indent=2)
    blocking_body = "\n".join(blocking or [])
    non_blocking_body = "\n".join(non_blocking or [])
    verdict_body = verdict or ""

    round_text = f"""## Review {review_count} — {now_iso()}

### Metadata
```json
{metadata_json}
```

### Automated Passes
{render_review_automated_passes(metadata.get("automated_passes"))}

### Blocking
{blocking_body}

### Non-blocking
{non_blocking_body}

### Verdict
{verdict_body}
"""

    if existing_text.strip():
        review_file.write_text(existing_text.rstrip() + "\n\n---\n\n" + round_text)
    else:
        review_file.write_text(round_text)
    return review_count


def upsert_review_block(text, review_block):
    """Replace the top-level review block or insert it before trailing metadata."""
    lines = text.splitlines(True)
    result = []
    i = 0
    replaced = False

    while i < len(lines):
        if re.match(r'^review:\s*$', lines[i]):
            replaced = True
            i += 1
            while i < len(lines):
                line = lines[i]
                if line.strip() and not line[0].isspace():
                    break
                i += 1
            continue
        result.append(lines[i])
        i += 1

    block_text = review_block.strip() + "\n"
    insert_idx = None
    for idx, line in enumerate(result):
        if re.match(r'^(self_eval|deviations|metadata):', line):
            insert_idx = idx
            break

    if insert_idx is None:
        if result and not result[-1].endswith("\n"):
            result[-1] += "\n"
        if result and result[-1].strip():
            result.append("\n")
        result.append(block_text)
    else:
        if insert_idx > 0 and result[insert_idx - 1].strip():
            result.insert(insert_idx, "\n")
            insert_idx += 1
        result.insert(insert_idx, block_text)

    return "".join(result)


