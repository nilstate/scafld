def now_iso():
    return datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).strftime("%Y-%m-%dT%H:%M:%SZ")


def find_root():
    """Walk up from cwd to find the project root (contains .ai/ dir)."""
    d = Path.cwd()
    while d != d.parent:
        if (d / AI_DIR).is_dir():
            return d
        # Also check for .trellis submodule
        if (d / ".trellis").is_dir():
            return d
        d = d.parent
    return None


def find_trellis_dir(root):
    """Find the trellis source directory (submodule or self)."""
    trellis = root / ".trellis"
    if trellis.is_dir() and (trellis / "cli" / "trellis").exists():
        return trellis
    # Maybe we're running from the trellis repo itself
    cli_path = root / "cli" / "trellis"
    if cli_path.exists():
        return root
    return None


def yaml_read_field(text, field):
    """Read a top-level YAML scalar field (simple regex, no library needed)."""
    m = re.search(rf'^{field}:\s*"?([^"\n]+)"?', text, re.MULTILINE)
    if m:
        return m.group(1).strip().strip('"').strip("'")
    return None


def yaml_set_field(text, field, value):
    """Set a top-level YAML scalar field."""
    quoted = f'"{value}"'
    new_text, n = re.subn(
        rf'^{field}:\s*.*$',
        f'{field}: {quoted}',
        text, count=1, flags=re.MULTILINE,
    )
    if n == 0:
        # Field not found - add after spec_version or at top
        new_text = f'{field}: {quoted}\n' + text
    return new_text


def yaml_read_nested(text, parent, field):
    """Read a field nested one level under a parent block."""
    in_parent = False
    for line in text.splitlines():
        if re.match(rf'^{parent}:', line):
            in_parent = True
            continue
        if in_parent:
            if line and not line[0].isspace():
                break
            m = re.match(rf'^\s+{field}:\s*"?([^"\n]+)"?', line)
            if m:
                return m.group(1).strip().strip('"').strip("'")
    return None


def count_phases(text):
    """Count phases and their statuses."""
    total = 0
    completed = 0
    failed = 0
    in_progress = 0
    for m in re.finditer(r'^\s+-\s+id:\s*"?phase\d+"?', text, re.MULTILINE):
        total += 1
    for m in re.finditer(r'^\s+status:\s*"?completed"?', text, re.MULTILINE):
        completed += 1
    for m in re.finditer(r'^\s+status:\s*"?failed"?', text, re.MULTILINE):
        failed += 1
    for m in re.finditer(r'^\s+status:\s*"?in_progress"?', text, re.MULTILINE):
        in_progress += 1
    # Subtract the top-level status from phase counts
    top_status = yaml_read_field(text, "status")
    if top_status == "completed":
        completed = max(0, completed - 1)
    elif top_status == "failed":
        failed = max(0, failed - 1)
    elif top_status == "in_progress":
        in_progress = max(0, in_progress - 1)
    return total, completed, failed, in_progress


def find_spec(root, task_id):
    """Find a spec file across all directories. Returns Path or None."""
    for folder in [DRAFTS_DIR, APPROVED_DIR, ACTIVE_DIR]:
        p = root / folder / f"{task_id}.yaml"
        if p.exists():
            return p
    # Search archive
    archive = root / ARCHIVE_DIR
    if archive.is_dir():
        for month_dir in sorted(archive.iterdir(), reverse=True):
            if month_dir.is_dir():
                p = month_dir / f"{task_id}.yaml"
                if p.exists():
                    return p
    return None


def find_all_specs(root):
    """Find all spec files. Returns list of (Path, folder_type)."""
    specs = []
    for label, folder in [("drafts", DRAFTS_DIR), ("approved", APPROVED_DIR), ("active", ACTIVE_DIR)]:
        d = root / folder
        if d.is_dir():
            for f in sorted(d.glob("*.yaml")):
                specs.append((f, label))
    archive = root / ARCHIVE_DIR
    if archive.is_dir():
        for month_dir in sorted(archive.iterdir(), reverse=True):
            if month_dir.is_dir():
                for f in sorted(month_dir.glob("*.yaml")):
                    specs.append((f, f"archive/{month_dir.name}"))
    return specs


def append_planning_log(text, summary, actor="cli"):
    """Append a planning_log entry to the spec text."""
    entry = f'  - timestamp: "{now_iso()}"\n    actor: "{actor}"\n    summary: "{summary}"'
    # Find planning_log section and append
    if re.search(r'^planning_log:', text, re.MULTILINE):
        # Find the last entry or the planning_log line itself
        # Insert before the next top-level key after planning_log
        lines = text.splitlines(True)
        insert_idx = None
        in_log = False
        for i, line in enumerate(lines):
            if re.match(r'^planning_log:', line):
                in_log = True
                continue
            if in_log:
                if line.strip() and not line[0].isspace():
                    insert_idx = i
                    break
        if insert_idx is None:
            # planning_log is at end of file
            text = text.rstrip('\n') + '\n' + entry + '\n'
        else:
            lines.insert(insert_idx, entry + '\n')
            text = ''.join(lines)
    else:
        text += f'\nplanning_log:\n{entry}\n'
    return text


def move_spec(root, spec_path, new_status):
    """Move spec to the correct folder and update status + timestamp."""
    text = spec_path.read_text()
    current_status = yaml_read_field(text, "status")

    # Validate transition
    allowed = VALID_TRANSITIONS.get(current_status, [])
    if new_status not in allowed:
        print(f"{c(C_RED, 'error')}: cannot transition from '{current_status}' to '{new_status}'")
        print(f"  allowed transitions: {', '.join(allowed) if allowed else 'none'}")
        sys.exit(1)

    # Update fields
    text = yaml_set_field(text, "status", new_status)
    text = yaml_set_field(text, "updated", now_iso())

    # Auto-append planning_log entry
    action_labels = {
        "approved": "Spec approved",
        "in_progress": "Execution started",
        "completed": "Spec completed",
        "failed": "Spec marked failed",
        "cancelled": "Spec cancelled",
    }
    text = append_planning_log(text, action_labels.get(new_status, f"Status changed to {new_status}"))

    # Determine destination
    if new_status in ("completed", "failed", "cancelled"):
        month = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m")
        dest_dir = root / ARCHIVE_DIR / month
    else:
        dest_dir = root / STATUS_FOLDERS[new_status]

    dest_dir.mkdir(parents=True, exist_ok=True)
    dest = dest_dir / spec_path.name

    spec_path.write_text(text)
    shutil.move(str(spec_path), str(dest))

    rel_from = spec_path.relative_to(root)
    rel_to = dest.relative_to(root)
    print(f"{c(C_GREEN, '  moved')}: {rel_from} -> {rel_to}")
    print(f" {c(C_DIM, 'status')}: {c(STATUS_COLORS.get(new_status, ''), new_status)}")
    return dest


def require_root():
    root = find_root()
    if not root:
        print(f"{c(C_RED, 'error')}: not in a Trellis project (no .ai/ directory found)")
        print(f"  run '{c(C_BOLD, 'trellis init')}' to set up a workspace")
        sys.exit(1)
    return root


def require_spec(root, task_id):
    spec = find_spec(root, task_id)
    if not spec:
        print(f"{c(C_RED, 'error')}: spec not found: {task_id}")
        print(f"  searched: {DRAFTS_DIR}/, {APPROVED_DIR}/, {ACTIVE_DIR}/, {ARCHIVE_DIR}/")
        sys.exit(1)
    return spec


