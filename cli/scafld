#!/usr/bin/env python3
"""Thin entrypoint that dispatches into the packaged scafld command implementation."""

import sys
from pathlib import Path


SCRIPT_ROOT = Path(__file__).resolve().parent.parent
if str(SCRIPT_ROOT) not in sys.path:
    sys.path.insert(0, str(SCRIPT_ROOT))

from scafld.commands.app import *  # noqa: F401,F403
from scafld.commands.app import main


if __name__ == "__main__":
    main()
