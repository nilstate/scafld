            "size": size,
            "risk": risk,
            "updated_at": updated,
            "phase_statuses": parse_phase_status_entries(text),
            "phase_counts": {
                "total": total,
                "completed": completed,
                "failed": failed,
                "in_progress": in_prog,
                "pending": total - completed - failed - in_prog,
            },
