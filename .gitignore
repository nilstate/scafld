# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
/build/
/dist/
/bin/*
!/bin/scafld
.tools/
*.egg-info/
*.tgz
*.test
coverage.out

# package build outputs
/package/pypi/build/
/package/pypi/dist/
/package/pypi/src/*.egg-info/

# OS
.DS_Store
Thumbs.db

# runx runtime state (governance receipts from runx-managed runs; never project-owned)
.runx/

# scafld runtime state
# Keep project-owned specs/config/prompts in git; ignore generated core and local runtime state.
!.scafld/
!.scafld/config.yaml
!.scafld/prompts/
!.scafld/prompts/**
!.scafld/specs/
!.scafld/specs/**
.scafld/specs/archive/
!.scafld/trusted-keys.json
!.scafld/receipts/
.scafld/receipts/*
!.scafld/receipts/*.json
.scafld/config.local.yaml
.scafld/core/
.scafld/keys/
.scafld/private-keys/
.scafld/**/*.key
.scafld/**/*.pem
.scafld/prompts/.manifest.json
.scafld/runs/
