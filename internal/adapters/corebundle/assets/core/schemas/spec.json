{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nilstate/scafld/spec-v2.0.json",
  "title": "scafld normalized task specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["spec_version", "task_id", "status", "title", "phases"],
  "properties": {
    "spec_version": {"type": "string", "const": "2.0"},
    "task_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "created": {"type": "string"},
    "updated": {"type": "string"},
    "title": {"type": "string", "minLength": 1},
    "summary": {"type": "string"},
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "active", "blocked", "review", "completed", "failed", "cancelled"]
    },
    "harden_status": {
      "type": "string",
      "enum": ["not_run", "in_progress", "passed", "needs_revision", "overridden", "error"]
    },
    "size": {"type": "string", "enum": ["small", "medium", "large"]},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "current_state": {"$ref": "#/definitions/current_state"},
    "context": {"$ref": "#/definitions/context"},
    "objectives": {"type": "array", "items": {"type": "string"}},
    "scope": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "touchpoints": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"$ref": "#/definitions/risk"}},
    "acceptance": {"$ref": "#/definitions/acceptance"},
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/phase"}
    },
    "rollback": {"type": "array", "items": {"type": "string"}},
    "review": {"$ref": "#/definitions/review"},
    "self_eval": {"type": "array", "items": {"type": "string"}},
    "deviations": {"type": "array", "items": {"type": "string"}},
    "metadata": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "origin": {"$ref": "#/definitions/origin"},
    "harden_rounds": {
      "type": "array",
      "items": {"$ref": "#/definitions/harden_round"}
    },
    "planning_log": {
      "type": "array",
      "items": {"$ref": "#/definitions/planning_event"}
    }
  },
  "definitions": {
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "current_phase": {"type": "string"},
        "next": {"type": "string"},
        "reason": {"type": "string"},
        "blockers": {"type": "string"},
        "allowed_follow_up": {"type": "string"},
        "latest_runner_update": {"type": "string"},
        "review_gate": {"type": "string"}
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cwd": {"type": "string"},
        "packages": {"type": "array", "items": {"type": "string"}},
        "files_impacted": {"type": "array", "items": {"type": "string"}},
        "invariants": {"type": "array", "items": {"type": "string"}},
        "related_docs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {"type": "string"},
        "mitigation": {"type": "string"}
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validation_profile": {"type": "string"},
        "definition_done": {
          "type": "array",
          "items": {"$ref": "#/definitions/checklist_item"}
        },
        "criteria": {
          "type": "array",
          "items": {"$ref": "#/definitions/criterion"}
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "number", "name"],
      "properties": {
        "id": {"type": "string", "pattern": "^phase[0-9]+$"},
        "number": {"type": "integer", "minimum": 1},
        "name": {"type": "string", "minLength": 1},
        "status": {"type": "string"},
        "reason": {"type": "string"},
        "dependencies": {"type": "array", "items": {"type": "string"}},
        "objective": {"type": "string"},
        "changes": {"type": "array", "items": {"type": "string"}},
        "acceptance": {
          "type": "array",
          "items": {"$ref": "#/definitions/criterion"}
        },
        "definition_done": {
          "type": "array",
          "items": {"$ref": "#/definitions/checklist_item"}
        }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "expected_kind"],
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "type": {"type": "string"},
        "phase_id": {"type": "string"},
        "command": {"type": "string"},
        "expected_kind": {
          "type": "string",
          "enum": ["exit_code_zero", "exit_code_nonzero", "no_matches", "manual", "browser_evidence"]
        },
        "status": {"type": "string"},
        "evidence": {"type": "string"},
        "source_event": {"type": "string"}
      }
    },
    "checklist_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "text": {"type": "string"},
        "checked": {"type": "boolean"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string"},
        "verdict": {"type": "string", "enum": ["pass", "fail", "none", ""]},
        "mode": {"type": "string", "enum": ["discover", "verify", ""]},
        "summary": {"type": "string"},
        "findings": {
          "type": "array",
          "items": {"$ref": "#/definitions/review_finding"}
        },
        "attack_log": {
          "type": "array",
          "items": {"type": "object"}
        },
        "budget": {"type": "object"},
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "output_format": {"type": "string"},
        "normalizations": {"type": "array", "items": {"type": "string"}}
      }
    },
    "review_finding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
        "blocks_completion": {"type": "boolean"},
        "category": {"type": "string"},
        "confidence": {"type": "string", "enum": ["high", "medium", "low", ""]},
        "location": {"$ref": "#/definitions/review_location"},
        "evidence": {"type": "string"},
        "impact": {"type": "string"},
        "reproducer": {"type": "string"},
        "suggested_fix": {"type": "string"},
        "validation": {"type": "string"},
        "related_spec": {"type": "string"},
        "review_pass": {"type": "string"},
        "status": {"type": "string", "enum": ["open", "fixed", "accepted_risk", "superseded", ""]},
        "summary": {"type": "string"}
      }
    },
    "review_location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string"},
        "line": {"type": "integer", "minimum": 1}
      }
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": {"type": "string"},
        "source": {"type": "string"}
      }
    },
    "harden_round": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^round-[0-9]+$"},
        "status": {"type": "string", "enum": ["in_progress", "passed", "needs_revision", "overridden", "error"]},
        "started_at": {"type": "string"},
        "ended_at": {"type": "string"},
        "spec_digest": {"type": "string"},
        "verdict": {"type": "string"},
        "summary": {"type": "string"},
        "diagnostic_path": {"type": "string"},
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "output_format": {"type": "string"},
        "shape": {"$ref": "#/definitions/harden_shape"},
        "observations": {
          "type": "array",
          "items": {"$ref": "#/definitions/harden_observation"}
        }
      }
    },
    "harden_shape": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision": {"type": "string", "enum": ["keep", "shrink", "reframe", "reject", ""]},
        "true_shape": {"type": "string"},
        "minimal_plan": {"type": "string"},
        "shared_owner": {"type": "string"},
        "adapter_boundaries": {"type": "array", "items": {"type": "string"}},
        "required_spec_edits": {"type": "array", "items": {"type": "string"}}
      }
    },
    "harden_observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {"type": "string", "enum": ["path", "command", "scope", "timing", "rollback", "design"]},
        "result": {"type": "string", "enum": ["clean", "advisory", "blocks", "n/a"]},
        "anchor": {"type": "string", "pattern": "^(spec_gap:|code:|archive:).+"},
        "note": {"type": "string"},
        "question": {"type": "string"},
        "recommended": {"type": "string"},
        "if_unanswered": {"type": "string"},
        "default": {"type": "string"},
        "status": {"type": "string", "enum": ["open", "fixed", "accepted_risk", "superseded"]}
      }
    },
    "planning_event": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time": {"type": "string"},
        "text": {"type": "string"}
      }
    }
  }
}
